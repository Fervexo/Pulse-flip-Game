.coin-gain{position:absolute;font-family:'Archivo Black',sans-serif;font-size:15px;color:var(--amber);text-shadow:0 0 10px rgba(255,210,63,0.7);pointer-events:none;z-index:6;animation:coinFloat 0.8s ease-out forwards;}
@keyframes coinFloat{0%{opacity:1;transform:translateY(0) scale(1);}100%{opacity:0;transform:translateY(-38px) scale(1.2);}}
.milestone-popup{position:absolute;top:30%;left:50%;transform:translate(-50%,-50%);background:rgba(10,14,31,0.92);border:1px solid rgba(255,255,255,0.15);border-radius:18px;padding:14px 26px;text-align:center;z-index:12;pointer-events:none;opacity:0;backdrop-filter:blur(8px);min-width:180px;}
.milestone-popup.show{animation:milestonePop 2.2s cubic-bezier(.22,1.1,.3,1) forwards;}
@keyframes milestonePop{0%{opacity:0;transform:translate(-50%,-50%) scale(0.7) translateY(20px);}15%{opacity:1;transform:translate(-50%,-50%) scale(1.04);}25%{transform:translate(-50%,-50%) scale(1);}75%{opacity:1;transform:translate(-50%,-50%) scale(1);}100%{opacity:0;transform:translate(-50%,-50%) scale(0.95) translateY(-16px);}}
.milestone-icon{font-size:26px;margin-bottom:3px;}
.milestone-title{font-family:'Archivo Black',sans-serif;font-size:13px;letter-spacing:3px;text-transform:uppercase;color:var(--amber);text-shadow:0 0 14px rgba(255,210,63,0.7);}
.milestone-desc{font-size:10px;color:var(--muted);letter-spacing:1px;margin-top:2px;}
.powerup-label{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Archivo Black',sans-serif;font-size:clamp(16px,4.5vw,28px);letter-spacing:4px;text-transform:uppercase;z-index:9;pointer-events:none;opacity:0;white-space:nowrap;}
.powerup-label.show{animation:powerupPop 1.5s ease forwards;}
@keyframes powerupPop{0%{opacity:0;transform:translate(-50%,-50%) scale(0.5);}20%{opacity:1;transform:translate(-50%,-50%) scale(1.1);}35%{transform:translate(-50%,-50%) scale(1);}70%{opacity:1;}100%{opacity:0;transform:translate(-50%,-68%);}}
.danger-bar{position:absolute;left:0;right:0;height:4px;pointer-events:none;z-index:6;opacity:0;transition:opacity .2s;}
.danger-bar.top{top:0;background:linear-gradient(90deg,transparent,#ff3caf,transparent);}
.danger-bar.bot{bottom:0;background:linear-gradient(90deg,transparent,#ff3caf,transparent);}
