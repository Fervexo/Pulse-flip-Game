.shop-close{width:36px;height:36px;border-radius:50%;border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.04);color:var(--ink);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;}
.shop-tabs{width:100%;max-width:480px;display:flex;gap:7px;margin-bottom:14px;overflow-x:auto;scrollbar-width:none;}
