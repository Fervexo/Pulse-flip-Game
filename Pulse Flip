    if(t.ghost)return 'rgba(255,255,255,0.6)';
    if(t.fire)return gravityDir>0?'#ff1a00':'#ff7a3c';
    if(t.ice)return gravityDir>0?'#4d9fff':'#bfefff';
    if(t.dark)return gravityDir>0?'#7c4dff':'#b388ff';
    if(t.sparkle){const h=(performance.now()/20)%360;return `hsl(${h},80%,80%)`;}
    if(t.lava)return gravityDir>0?'#ff3c00':'#ffaa00';
    if(t.electric){const h2=(performance.now()/15)%360;return `hsl(${h2},100%,75%)`;}
    return gravityDir>0?t.colors[0]:t.colors[1];
  }
