  function updateSoundBtn(){soundBtn.textContent=playerData.settings.muted?'🔇':'🔊';}

  // ===== SAVE/LOAD =====
  async function loadPlayerData(){
    let raw=null;
    try{if(window.storage){const r=await window.storage.get(SAVE_KEY);if(r&&r.value)raw=r.value;}}catch(e){}
    if(raw===null){try{if(window.localStorage)raw=window.localStorage.getItem(SAVE_KEY);}catch(e){}}
    if(raw){
      try{
        const loaded=JSON.parse(raw);
        playerData=Object.assign(playerData,loaded);
        if(loaded.owned)playerData.owned=Object.assign({skins:['classic'],trails:['classic'],backgrounds:['space']},loaded.owned);
        if(loaded.equipped)playerData.equipped=Object.assign({skin:'classic',trail:'classic',background:'space'},loaded.equipped);
        playerData.settings=Object.assign({muted:false},loaded.settings||{});
        playerData.stats=Object.assign({totalRuns:0,totalFlips:0,totalNearMisses:0,longestRun:0,maxLevelReached:0,totalSpent:0,maxStreak:0,totalCoinsEarned:0,dailyStreak:0,lastPlayDate:'',totalSuperFlips:0,bossesDefeated:0,questsCompleted:0,totalXP:0,playerLevel:1},loaded.stats||{});
        playerData.achievements=loaded.achievements||[];
        playerData.powerupInventory=Object.assign({shield:0,slowmo:0,magnet:0,ghost:0,doubler:0,tiny:0,nuke:0,timewarp:0},loaded.powerupInventory||{});
        playerData.dailyChallenge=Object.assign({date:'',score:0,target:0,done:false},loaded.dailyChallenge||{});
        playerData.dailyReward=Object.assign({lastDate:'',streak:0,claimed:false},loaded.dailyReward||{});
        playerData.highestLevel=loaded.highestLevel||1;
        playerData.startFromLevel=loaded.startFromLevel||1;
        playerData.selectedMode=loaded.selectedMode||'classic';
        playerData.upgradeLevel=Object.assign({gap_size:0,coin_mult:0,start_speed:0,powerup_dur:0,charge_tap:0,shield_hit:0,coin_start:0},loaded.upgradeLevel||{});
        playerData.questProgress=loaded.questProgress||{};
        playerData.questCompleted=loaded.questCompleted||{};
      }catch(e){}
    }
    best=playerData.best||0;
    selectedStartLevel=Math.min(playerData.highestLevel||1,Math.max(1,playerData.startFromLevel||1));
    bestEl.textContent='BEST '+best;
    updateCoinDisplays();
    updateSoundBtn();
    updateLobby();
    buildLevelNav();
    buildModeSelect();
    genBackground();
    checkDailyChallenge();
    checkDailyReward();
    updateXP();
  }
  async function savePlayerData(){
    const json=JSON.stringify(playerData);
    try{if(window.storage)await window.storage.set(SAVE_KEY,json);}catch(e){}
    try{if(window.localStorage)window.localStorage.setItem(SAVE_KEY,json);}catch(e){}
  }

  function updateCoinDisplays(){
    hudCoinsEl.textContent=playerData.coins;
    startCoinsEl.textContent=playerData.coins;
    shopCoinsEl.textContent=playerData.coins;
    upgradesCoinsEl.textContent=playerData.coins;
    if(startBestNum)startBestNum.textContent=best;
  }

  // ===== XP SYSTEM =====
  function addXP(amount){
    playerData.stats.totalXP=(playerData.stats.totalXP||0)+amount;
    const newLevel=Math.floor(Math.sqrt(playerData.stats.totalXP/50))+1;
    if(newLevel>(playerData.stats.playerLevel||1)){
      playerData.stats.playerLevel=newLevel;
      showMilestone('⭐','PLAYER LEVEL UP','You are now Level '+newLevel+'!');
      playerData.coins+=newLevel*20;
      playerData.stats.totalCoinsEarned+=newLevel*20;
      updateCoinDisplays();
    }
    updateXP();
  }
  function updateXP(){
    const lvl=playerData.stats.playerLevel||1;
    const xpForLevel=lvl*lvl*50;
    const xpPrev=(lvl-1)*(lvl-1)*50;
    const prog=Math.min(1,(playerData.stats.totalXP-xpPrev)/(xpForLevel-xpPrev||1));
    xpFill.style.width=(prog*100)+'%';
  }

  // ===== GAME STATE =====
  let state='start';
  let player,obstacles,particles,gravityDir,vy,score,comboTimer,comboMultStreak;
  let speed,spawnTimer,spawnInterval,t0,elapsed;
  let shakeMag=0,bgHue=0,currentRunLevel=1,runCoins=0,currentStartLevel=1;
  let nearMissStreak=0,maxStreakThisRun=0;
  let activePowerup=null,powerupTimer=0;
  let coinMagnetActive=false,coinDoublerActive=false;
  let shieldActive=false,ghostActive=false,slowmoActive=false,tinyActive=false,timewarpActive=false;
  let shieldHitsLeft=0;
  let collectibles=[],bgParticles=[];
  let runStart=0;
  let W,H,DPR;
  let stars=[],orbs=[];
  let currentMode='classic';
  let timeAttackTimer=30;
  let bossData=null,bossIndex=0;
  let runFlips=0,runNearMiss=0,runSuperFlips=0;

  // CHARGE SYSTEM
  let tapCharge=0;
  let chargeResetTimer=0;
  const CHARGE_RESET_TIME=2.5;

  function resize(){
    DPR=Math.min(window.devicePixelRatio||1,2);
    W=window.innerWidth;H=window.innerHeight;
    canvas.width=W*DPR;canvas.height=H*DPR;
    canvas.style.width=W+'px';canvas.style.height=H+'px';
    ctx.setTransform(DPR,0,0,DPR,0,0);
    genBackground();
  }
  window.addEventListener('resize',resize);
  resize();

  function genBackground(){
    stars=[];
    const count=Math.floor((W*H)/9000);
    for(let i=0;i<count;i++){
      stars.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.6+0.4,phase:Math.random()*Math.PI*2,speed:0.6+Math.random()*1.2});
    }
    orbs=[];
    const colors=currentTheme().orbColors;
    for(let i=0;i<5;i++){
      orbs.push({x:Math.random()*W,y:Math.random()*H,r:60+Math.random()*120,color:colors[i%colors.length],speed:6+Math.random()*10,dir:Math.random()*Math.PI*2});
    }
    bgParticles=[];
  }
  function currentTheme(){
    if(state==='playing')return getRunTheme(currentRunLevel);
    return activeBg();
  }
  function recolorOrbs(theme){const colors=theme.orbColors;orbs.forEach((o,i)=>{o.color=colors[i%colors.length];});}

  // ===== MODE SELECT =====
  function buildModeSelect(){
    modeGrid.innerHTML='';
    GAME_MODES.forEach(mode=>{
      const card=document.createElement('div');
      const isSelected=playerData.selectedMode===mode.id;
      const isLocked=best<mode.unlockAt;
      card.className='mode-card'+(isSelected?' selected':'')+(isLocked?' locked':'');
      card.innerHTML=`<div class="mode-icon">${mode.icon}</div><div class="mode-name">${mode.name}</div><div class="mode-desc">${isLocked?'Score '+mode.unlockAt+' to unlock':mode.desc}</div>`;
      if(!isLocked){
        card.addEventListener('click',e=>{e.stopPropagation();sfxClick();playerData.selectedMode=mode.id;savePlayerData();buildModeSelect();});
      }
      modeGrid.appendChild(card);
    });
  }

  // ===== CHARGE HUD =====
  function updateChargeHud(){
    if(state!=='playing'){chargeHud.classList.remove('visible');return;}
    const needed=getChargeTaps();
    chargeHud.classList.toggle('visible',true);
    chargeFill.style.width=(tapCharge/needed*100)+'%';
    chargePips.innerHTML='';
    for(let i=0;i<needed;i++){
      const pip=document.createElement('div');
      pip.className='charge-pip'+(i<tapCharge?' lit':'');
      chargePips.appendChild(pip);
    }
  }

  // ===== GAME RESET =====
  function reset(){
    currentMode=playerData.selectedMode||'classic';
    currentStartLevel=selectedStartLevel||1;
    player={x:0,y:0};
    vy=0;gravityDir=1;
    obstacles=[];particles=[];collectibles=[];
    score=0;
    const speedReduction=getUpgradeLevel('start_speed')*20;
    speed=Math.max(150,270+(currentStartLevel-1)*30-speedReduction);
    spawnTimer=0;
    spawnInterval=Math.max(0.6,1.35-(currentStartLevel-1)*0.08);
    shakeMag=0;comboTimer=0;elapsed=0;
    player.x=W*PLAYER_X_RATIO;player.y=H/2;
    vy=0;currentRunLevel=currentStartLevel;runCoins=0;
    nearMissStreak=0;maxStreakThisRun=0;
    activePowerup=null;powerupTimer=0;
    shieldActive=false;ghostActive=false;
    coinMagnetActive=false;coinDoublerActive=false;slowmoActive=false;tinyActive=false;timewarpActive=false;
    shieldHitsLeft=0;
    tapCharge=0;chargeResetTimer=0;
    runFlips=0;runNearMiss=0;runSuperFlips=0;
    bossData=null;bossIndex=0;
    bossHud.classList.remove('show');
    timerHud.classList.remove('show','urgent');
    timeAttackTimer=30;
    runStart=performance.now();
    // Bonus start coins from upgrade
    const bonusCoins=getStartCoinsBonus();
    if(bonusCoins>0){runCoins+=bonusCoins;hudCoinsEl.textContent=playerData.coins+runCoins;}
    updateLevelHud(0);
    genBackground();
    updateChargeHud();
  }

  function flip(){
    if(state!=='playing')return;
    tapCharge++;
    chargeResetTimer=CHARGE_RESET_TIME;
    sfxChargePip();
    playerData.stats.totalFlips++;
    runFlips++;
    updateChargeHud();

    const needed=getChargeTaps();
    if(tapCharge>=needed){
      // SUPER FLIP!
      superFlip();
      tapCharge=0;
      chargeResetTimer=0;
    } else {
      // Normal flip
      gravityDir*=-1;
      vy=-FLIP_IMPULSE*gravityDir;
      sfxFlip();
      const sk=activeSkin();const skinColors=activeSkinColor();
      burst(player.x,player.y,gravityDir>0?skinColors[1]:skinColors[0],10);
    }
    checkDangerWarning();
  }

  function superFlip(){
    playerData.stats.totalSuperFlips=(playerData.stats.totalSuperFlips||0)+1;
    runSuperFlips++;
    // Do a big flip with inverted gravity and visual effects
    gravityDir*=-1;
    vy=-FLIP_IMPULSE*1.8*gravityDir;
    sfxSuperFlip();
    // Big burst
    burst(player.x,player.y,'#b388ff',30,1.5);
    burst(player.x,player.y,'#4deeea',20,2);
    burstRing(player.x,player.y,'#ffd23f');
    // Clear nearby obstacles
    const cleared=[];
    obstacles.forEach((o,i)=>{
      if(o.x<player.x+W*0.35&&o.x>player.x-W*0.1){
        cleared.push(i);
        burst((o.x+o.width/2),H/2,'#ff3caf',15);
      }
    });
    for(let i=cleared.length-1;i>=0;i--)obstacles.splice(cleared[i],1);
    // Flash
    flashEl.style.transition='opacity .05s ease';flashEl.style.opacity='0.4';
    setTimeout(()=>{flashEl.style.transition='opacity .6s ease';flashEl.style.opacity='0';},50);
    // Shake
    shakeMag=Math.max(shakeMag,20);
    // Banner
    superFlipBanner.style.color='#b388ff';
    superFlipBanner.style.textShadow='0 0 30px #b388ff, 0 0 60px #4deeea';
    superFlipBanner.classList.remove('show');void superFlipBanner.offsetWidth;superFlipBanner.classList.add('show');
    showMilestone('⚡','SUPER FLIP!','Charge complete!');
    // Temp invincibility
    const prevShield=shieldActive;
    shieldActive=true;shieldHitsLeft=999;
    setTimeout(()=>{if(!prevShield){shieldActive=false;shieldHitsLeft=0;}},800);
    checkAchievements();
  }

  function checkDangerWarning(){
    const nearTop=player.y<H*0.12;
    const nearBot=player.y>H*0.88;
    dangerTop.classList.toggle('show',nearTop&&gravityDir<0);
    dangerBot.classList.toggle('show',nearBot&&gravityDir>0);
  }

  function startGame(){
    unlockAudio();
    reset();
    state='playing';
    startScreen.classList.add('hidden');
    overScreen.classList.add('hidden');
    levelHud.style.display='flex';
    buildPowerupHud();
    t0=performance.now();
    if(playerData.stats.totalRuns===0){
      const hint=document.createElement('div');
      hint.className='hint-bar';
      hint.textContent='TAP '+getChargeTaps()+'x TO SUPER FLIP!';
      document.getElementById('wrap').appendChild(hint);
      setTimeout(()=>hint.remove(),4200);
    }
    if(currentMode==='timeatt'){
      timerHud.textContent='30';timerHud.classList.add('show');timerHud.classList.remove('urgent');
      timeAttackTimer=30;
    }
    if(currentMode==='boss'){
      spawnBoss(0);
    }
    requestAnimationFrame(loop);
  }

  // ===== BOSS SYSTEM =====
  function spawnBoss(idx){
    if(idx>=BOSSES.length)return;
    const b=BOSSES[idx];
    bossData={...b,currentHp:b.hp,hitsUntilPhase:b.phaseAt,phase:1};
    bossIndex=idx;
    bossName.textContent=b.icon+' '+b.name;
    bossFill.style.width='100%';
    bossFill.style.background=`linear-gradient(90deg,${b.color}88,${b.color})`;
    bossHud.classList.add('show');
    showMilestone(b.icon,'BOSS INCOMING!',b.name+' is here!');
    sfxLevelUp();
  }

  function hitBoss(){
    if(!bossData)return;
    bossData.currentHp--;
    sfxBossHit();
    bossFill.style.width=(bossData.currentHp/bossData.hp*100)+'%';
    burst(W*0.8,H*0.3,bossData.color,8);
    if(bossData.currentHp<=0){
      // Boss dead
      sfxBossDead();
      playerData.stats.bossesDefeated=(playerData.stats.bossesDefeated||0)+1;
      runCoins+=bossData.reward;
      spawnCoinGain('+'+bossData.reward,W/2,H/2,'#ffd23f');
      showMilestone('🏆','BOSS DEFEATED!',bossData.name+' destroyed! +'+bossData.reward+' coins');
      burstRing(W/2,H/2,'#ffd23f');
      burst(W/2,H/2,'#ff3caf',40,2);
      bossData=null;
      bossHud.classList.remove('show');
      // Spawn next boss after delay
      const nextIdx=bossIndex+1;
      if(nextIdx<BOSSES.length){
        setTimeout(()=>{if(state==='playing')spawnBoss(nextIdx);},3000);
      } else {
        showMilestone('🔱','ALL BOSSES DEFEATED!','You are a legend!');
      }
      checkAchievements();
      savePlayerData();
    }
  }

  function endGame(){
    state='over';
    shakeMag=18;sfxCrash();
    levelHud.style.display='none';
    powerupHud.classList.remove('active');
    chargeHud.classList.remove('visible');
    timerHud.classList.remove('show');
    bossHud.classList.remove('show');
    dangerTop.classList.remove('show');dangerBot.classList.remove('show');
    streakBadge.classList.remove('show');

    flashEl.style.transition='opacity .05s ease';flashEl.style.opacity='0.6';
    setTimeout(()=>{flashEl.style.transition='opacity .4s ease';flashEl.style.opacity='0';},40);

    // Mode-specific final score display
    if(currentMode==='timeatt'){
      finalScoreEl.textContent=score;
      finalLabelEl.textContent='pillars in 30 seconds';
    } else {
      finalScoreEl.textContent=score;
      finalLabelEl.textContent='pillars passed';
    }

    const runTime=(performance.now()-runStart)/1000;
    playerData.stats.totalRuns++;
    playerData.stats.longestRun=Math.max(playerData.stats.longestRun,runTime);
    playerData.stats.maxLevelReached=Math.max(playerData.stats.maxLevelReached,currentRunLevel);
    playerData.stats.maxStreak=Math.max(playerData.stats.maxStreak,maxStreakThisRun);

    const absoluteScore=score+(currentStartLevel-1)*PILLARS_PER_LEVEL;
    if(absoluteScore>best){
      best=absoluteScore;playerData.best=best;
      newBestEl.style.display='block';
    } else {newBestEl.style.display='none';}
    bestEl.textContent='BEST '+best;

    if(currentRunLevel>playerData.highestLevel){playerData.highestLevel=currentRunLevel;}

    // Quest progress
    updateQuestProgress('score',score);
    updateQuestProgress('flips',runFlips);
    updateQuestProgress('near',runNearMiss);
    updateQuestProgress('coins',runCoins);
    updateQuestProgress('level',currentRunLevel);
    updateQuestProgress('time',Math.floor(runTime));
    updateQuestProgress('super',runSuperFlips);
    if(currentMode==='boss'&&bossIndex>=0)updateQuestProgress('boss',bossIndex+1);

    // Daily challenge
    const dc=playerData.dailyChallenge;
    const today=new Date().toISOString().slice(0,10);
    if(dc.date===today&&!dc.done&&score>=dc.target){
      dc.done=true;dc.score=score;
      runCoins+=dc.target;
      showMilestone('⚡','DAILY DONE!','Bonus coins awarded!');
    }
    checkDailyChallenge();

    playerData.coins+=runCoins;
    playerData.stats.totalCoinsEarned+=runCoins;
    coinsEarnedEl.textContent='+'+runCoins;
    coinsMultiplierEl.textContent=currentRunLevel>currentStartLevel?('Reached Lv.'+currentRunLevel):'';
    updateCoinDisplays();

    if(currentRunLevel>currentStartLevel){
      levelUpNum.textContent='Level '+currentRunLevel;
      levelUpBanner.style.display='block';
      levelUpBanner.style.animation='none';
      void levelUpBanner.offsetWidth;
      levelUpBanner.style.animation='';
    } else {levelUpBanner.style.display='none';}

    // XP
    addXP(Math.floor(score/2)+currentRunLevel*5+runSuperFlips*10);

    updateLobby();
    buildLevelNav();
    buildModeSelect();
    checkAchievements();
    savePlayerData();
    setTimeout(()=>{overScreen.classList.remove('hidden');},380);
  }

  // ===== QUEST PROGRESS =====
  function updateQuestProgress(type,value){
    QUESTS.forEach(q=>{
      if(playerData.questCompleted[q.id])return;
      if(q.type!==type)return;
      if(q.mode&&q.mode!==currentMode)return;
      const prev=playerData.questProgress[q.id]||0;
      const newVal=Math.max(prev,value);
      playerData.questProgress[q.id]=newVal;
      if(newVal>=q.target&&!playerData.questCompleted[q.id]){
        playerData.questCompleted[q.id]=true;
        playerData.stats.questsCompleted=(playerData.stats.questsCompleted||0)+1;
        playerData.coins+=q.reward;
        playerData.stats.totalCoinsEarned+=q.reward;
        showMilestone('📋','QUEST DONE!',q.name+' +'+q.reward+' coins');
        updateCoinDisplays();
        checkAchievements();
      }
    });
  }

  // ===== PARTICLES =====
  function burst(x,y,color,n,spread){
    spread=spread||1;
    for(let i=0;i<n;i++){
      const a=Math.random()*Math.PI*2;const sp=60+Math.random()*220*spread;
      particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,life:0.4+Math.random()*0.4,age:0,color,size:2+Math.random()*3});
    }
  }
  function burstRing(x,y,color){
    for(let i=0;i<20;i++){
      const a=(i/20)*Math.PI*2;
      particles.push({x,y,vx:Math.cos(a)*200,vy:Math.sin(a)*200,life:0.5,age:0,color,size:3});
    }
  }

  // ===== OBSTACLES =====
  function getObstacleStyle(){return (getRunTheme(currentRunLevel).obstacleStyle)||'pillar';}
  function spawnObstacle(){
    // Survival mode: gap shrinks faster
    let gapReduction=0;
    if(currentMode==='survival')gapReduction=Math.floor(score/5)*6;
    const gapH=Math.max(80,240-score*1.1-elapsed*1.6+getGapBonus()-gapReduction);
    const margin=60;const gapY=margin+Math.random()*(H-margin*2-gapH)+gapH/2;
    // Moving wall in boss mode / high levels
    const isMoving=(currentMode==='boss'&&bossData&&bossData.currentHp<=bossData.phaseAt)||(currentRunLevel>=8&&Math.random()<0.3);
    obstacles.push({x:W+40,width:26,gapY,gapH,passed:false,flashT:0,style:getObstacleStyle(),accentColor:getRunTheme(currentRunLevel).gapGlow,
      moving:isMoving,moveDir:Math.random()<0.5?1:-1,moveSpeed:60+Math.random()*80,moveRange:H*0.2});
    if(Math.random()<0.3&&score>5){
      collectibles.push({x:W+80,y:gapY,r:8,collected:false,color:'#ffd23f',pulse:0});
    }
    if(currentRunLevel>=6&&Math.random()<0.18){
      const gapH2=Math.max(120,gapH+10);
      const gapY2=margin+Math.random()*(H-margin*2-gapH2)+gapH2/2;
      setTimeout(()=>{
        if(state==='playing')obstacles.push({x:W+40+speed*0.38,width:26,gapY:gapY2,gapH:gapH2,passed:false,flashT:0,style:getObstacleStyle(),accentColor:getRunTheme(currentRunLevel).gapGlow,moving:false});
      },380);
    }
    // Boss mode: spawn double obstacles in phase 2
    if(bossData&&bossData.currentHp<=bossData.phaseAt&&Math.random()<0.4){
      const gapH3=Math.max(100,gapH);
      const gapY3=margin+Math.random()*(H-margin*2-gapH3)+gapH3/2;
      setTimeout(()=>{
        if(state==='playing')obstacles.push({x:W+80,width:20,gapY:gapY3,gapH:gapH3,passed:false,flashT:0,style:'neon',accentColor:'#ff3caf',moving:false,bossWall:true});
      },200);
    }
  }

  // ===== POWERUPS =====
  function activatePowerup(type){
    const def=POWERUP_TYPES.find(p=>p.id===type);if(!def)return;
    activePowerup=type;
    const durBonus=getPowerupDurBonus();
    powerupTimer=def.duration+durBonus;
    shieldActive=type==='shield';ghostActive=type==='ghost';
    slowmoActive=type==='slowmo';coinMagnetActive=type==='magnet';coinDoublerActive=type==='doubler';
    tinyActive=type==='tiny';timewarpActive=type==='timewarp';
    if(type==='shield')shieldHitsLeft=getShieldHits();
    if(type==='nuke'){
      // Nuke: clear all obstacles
      sfxNuke();
      const count=obstacles.length;
      obstacles.forEach(o=>burst((o.x+o.width/2),H/2,'#ff3c00',8));
      obstacles=[];
      flashEl.style.transition='opacity .05s ease';flashEl.style.opacity='0.7';
      setTimeout(()=>{flashEl.style.transition='opacity .5s ease';flashEl.style.opacity='0';},50);
      shakeMag=Math.max(shakeMag,25);
      showMilestone('💣','NUKE!','Blasted '+count+' walls!');
      if(bossData){hitBoss();hitBoss();}// nuke damages boss
      activePowerup=null;
      updatePowerupHud();
      return;
    }
    powerupLabel.textContent=def.icon+' '+def.name;
    powerupLabel.style.color=def.color;powerupLabel.style.textShadow=`0 0 20px ${def.color}`;
    powerupLabel.classList.remove('show');void powerupLabel.offsetWidth;powerupLabel.classList.add('show');
    sfxPowerup();burstRing(player.x,player.y,def.color);
    updatePowerupHud();
  }
  function deactivatePowerup(){
    activePowerup=null;shieldActive=false;ghostActive=false;slowmoActive=false;
    coinMagnetActive=false;coinDoublerActive=false;tinyActive=false;timewarpActive=false;
    updatePowerupHud();
  }

  // ===== POWERUP HUD =====
  function buildPowerupHud(){
    powerupHud.innerHTML='';
    POWERUP_TYPES.forEach(pt=>{
      const count=playerData.powerupInventory[pt.id]||0;
      const slot=document.createElement('div');
      slot.className='pu-slot'+(count>0?' has-item':' empty');
      slot.dataset.type=pt.id;
      slot.innerHTML=`<div class="pu-icon">${pt.icon}</div>${count>0?`<div class="pu-count">${count}</div>`:''}`;
      slot.title=pt.name+': '+pt.desc;
      if(count>0){
        slot.addEventListener('pointerdown',e=>{
          e.stopPropagation();
          if(state!=='playing')return;
          if(activePowerup)return;
          if((playerData.powerupInventory[pt.id]||0)<=0)return;
          playerData.powerupInventory[pt.id]--;
          savePlayerData();
          activatePowerup(pt.id);
          buildPowerupHud();
        });
      }
      powerupHud.appendChild(slot);
    });
    const hasAny=POWERUP_TYPES.some(pt=>(playerData.powerupInventory[pt.id]||0)>0);
    powerupHud.classList.toggle('active',hasAny&&state==='playing');
  }
  function updatePowerupHud(){buildPowerupHud();}

  // ===== MILESTONES =====
  function showMilestone(icon,title,desc){
    milestoneIcon.textContent=icon;milestoneTitle.textContent=title;milestoneDesc.textContent=desc;
    milestonePopup.classList.remove('show');void milestonePopup.offsetWidth;milestonePopup.classList.add('show');
    sfxMilestone();
  }

  // ===== MAIN LOOP =====
  let last=0;
  function loop(now){
    if(state!=='playing')return;
    if(!last)last=now;
    let dt=(now-last)/1000;dt=Math.min(dt,0.033);last=now;
    if(slowmoActive)dt*=0.5;
    if(timewarpActive)dt*=0.3;
    update(dt);render();
    requestAnimationFrame(loop);
  }

  function update(dt){
    bgHue+=dt*6;elapsed+=dt;

    if(activePowerup){powerupTimer-=dt;if(powerupTimer<=0)deactivatePowerup();}

    // Charge reset timer
    if(tapCharge>0){
      chargeResetTimer-=dt;
      if(chargeResetTimer<=0){tapCharge=0;chargeResetTimer=0;updateChargeHud();}
    }

    // Time Attack countdown
    if(currentMode==='timeatt'){
      timeAttackTimer-=dt;
      timerHud.textContent=Math.max(0,Math.ceil(timeAttackTimer));
      timerHud.classList.toggle('urgent',timeAttackTimer<=10&&timeAttackTimer>0);
      if(timeAttackTimer<=0){endGame();return;}
    }

    vy+=GRAVITY*gravityDir*dt;
    const effectiveR=tinyActive?PLAYER_R*0.55:PLAYER_R;
    player.y+=vy*dt;

    const ceilY=effectiveR,floorY=H-effectiveR;
    if(player.y<ceilY){player.y=ceilY;vy=0;if(!shieldActive&&!ghostActive){burst(player.x,player.y,'#ff3caf',24);endGame();return;}}
    if(player.y>floorY){player.y=floorY;vy=0;if(!shieldActive&&!ghostActive){burst(player.x,player.y,'#ff3caf',24);endGame();return;}}

    const trailRate=activeTrail().fire?0.9:(activeTrail().ghost?0.4:0.6);
    if(Math.random()<trailRate){
      particles.push({x:player.x-PLAYER_R*0.6+(Math.random()-0.5)*6,y:player.y+(Math.random()-0.5)*6,
        vx:-speed*0.4+(Math.random()-0.5)*30,vy:(Math.random()-0.5)*40,
        life:0.3+Math.random()*0.25,age:0,color:activeTrailColor(),size:1+Math.random()*2});
    }

    spawnTimer+=dt;
    if(spawnTimer>=spawnInterval){spawnTimer=0;spawnObstacle();}

    const levelBonus=(currentRunLevel-1)*15;
    speed=Math.min(270+score*4+elapsed*5+levelBonus,1100);
    spawnInterval=Math.max(0.38,1.35-score*0.01-elapsed*0.012-(currentRunLevel-1)*0.02);

    for(let i=obstacles.length-1;i>=0;i--){
      const o=obstacles[i];
      o.x-=speed*dt;
      // Moving obstacle
      if(o.moving){
        o.gapY+=o.moveDir*o.moveSpeed*dt;
        const gapMin=60+o.gapH/2;const gapMax=H-60-o.gapH/2;
        if(o.gapY<gapMin){o.gapY=gapMin;o.moveDir=1;}
        if(o.gapY>gapMax){o.gapY=gapMax;o.moveDir=-1;}
      }

      if(!ghostActive){
        const px=player.x,py=player.y,r=effectiveR;
        if(px+r>o.x&&px-r<o.x+o.width){
          const gapTop=o.gapY-o.gapH/2;const gapBot=o.gapY+o.gapH/2;
          if(py-r<gapTop||py+r>gapBot){
            if(shieldActive&&shieldHitsLeft>0){
              shieldHitsLeft--;
              if(shieldHitsLeft<=0){shieldActive=false;powerupTimer=0;deactivatePowerup();}
              burst(player.x,player.y,'#4deeea',30,1.5);sfxPowerup();
              obstacles.splice(i,1);
              if(bossData)hitBoss();
              continue;
            }
            burst(player.x,player.y,'#ff3caf',24);endGame();return;
          } else {
            if(o.flashT===0){
              const distTop=Math.abs(py-r-gapTop);const distBot=Math.abs(py+r-gapBot);
              if(Math.min(distTop,distBot)<14){
                nearMissStreak++;runNearMiss++;maxStreakThisRun=Math.max(maxStreakThisRun,nearMissStreak);
                playerData.stats.totalNearMisses++;
                showCombo(nearMissStreak);
                if(nearMissStreak>=3){streakBadge.classList.add('show');streakCount.textContent=nearMissStreak;sfxStreak();}
                if(nearMissStreak>=3){
                  const bonus=nearMissStreak;runCoins+=bonus;
                  spawnCoinGain('+'+bonus+'🔥',player.x,player.y-25,'#ff3caf');
                }
                // Boss mode: near miss damages boss
                if(bossData&&nearMissStreak>=2)hitBoss();
              }
            } else {nearMissStreak=0;streakBadge.classList.remove('show');}
          }
        }
      }

      if(!o.passed&&o.x+o.width<player.x-effectiveR){
        o.passed=true;score++;scoreEl.textContent=score;
        const newLevel=levelForScore(score,currentStartLevel);
        const coinBase=newLevel+getCoinMultBonus();
        const coinValue=coinBase*(coinDoublerActive?2:1);
        runCoins+=coinValue;
        hudCoinsEl.textContent=playerData.coins+runCoins;
        sfxScore();updateLevelHud(score);
        burst(player.x,player.y,'#ffd23f',6);
        spawnCoinGain('+'+coinValue,player.x+14,player.y-30,'#ffd23f');

        if(newLevel>currentRunLevel){
          currentRunLevel=newLevel;onLevelUp(currentRunLevel);
        }

        if(score===10)showMilestone('⭐','10 PILLARS','Just warming up!');
        if(score===25)showMilestone('🔥','25 PILLARS','Getting serious!');
        if(score===50)showMilestone('💯','50 PILLARS','Incredible!');
        if(score===100)showMilestone('👑','100 PILLARS','LEGENDARY!');
        if(score===250)showMilestone('🏆','250 PILLARS','MYTHIC!');

        const dc=playerData.dailyChallenge;
        const today=new Date().toISOString().slice(0,10);
        if(dc.date===today&&!dc.done)dc.score=score;

        if(score>10&&Math.random()<0.04){
          const puType=POWERUP_TYPES[Math.floor(Math.random()*POWERUP_TYPES.length)];
          collectibles.push({x:W+100,y:H*0.2+Math.random()*H*0.6,r:12,collected:false,color:puType.color,pulse:0,powerup:puType.id,icon:puType.icon});
        }
      }
      if(o.x+o.width<-10)obstacles.splice(i,1);
    }

    for(let i=collectibles.length-1;i>=0;i--){
      const c=collectibles[i];
      c.x-=speed*dt;c.pulse=(c.pulse||0)+dt*4;
      if(coinMagnetActive&&!c.powerup){
        const dx=player.x-c.x,dy=player.y-c.y;const dist=Math.sqrt(dx*dx+dy*dy);
        if(dist<200){c.x+=dx/dist*400*dt;c.y+=dy/dist*400*dt;}
      }
      const dx=player.x-c.x,dy=player.y-c.y;
      if(Math.sqrt(dx*dx+dy*dy)<effectiveR+c.r){
        c.collected=true;
        if(c.powerup){activatePowerup(c.powerup);}
        else{const val=coinDoublerActive?4:2;runCoins+=val;spawnCoinGain('+'+val,c.x,c.y,'#ffd23f');burst(c.x,c.y,'#ffd23f',8);sfxScore();}
        collectibles.splice(i,1);continue;
      }
      if(c.x<-20)collectibles.splice(i,1);
    }

    for(let i=particles.length-1;i>=0;i--){
      const p=particles[i];p.age+=dt;
      if(p.age>=p.life){particles.splice(i,1);continue;}
      p.x+=p.vx*dt;p.y+=p.vy*dt;p.vy+=400*dt;p.vx*=0.96;
    }

    if(shakeMag>0)shakeMag*=0.88;
    if(comboShowTimer>0){comboShowTimer-=dt;if(comboShowTimer<=0)comboEl.classList.remove('show');}
    checkDangerWarning();
  }

  let comboShowTimer=0;
  function showCombo(streak){
    const msgs=['CLOSE CALL!','RISKY!','RAZOR EDGE!','INSANE!','GODLIKE!','UNSTOPPABLE!'];
    comboEl.textContent=msgs[Math.min(streak-1,msgs.length-1)];
    comboEl.classList.add('show');comboShowTimer=0.6;sfxClose();burst(player.x,player.y,'#ffd23f',4);
  }

  function onLevelUp(level){
    sfxLevelUp();shakeMag=Math.max(shakeMag,14);
    const theme=getRunTheme(level);recolorOrbs(theme);
    levelFlashEl.style.background=theme.accent;levelFlashEl.style.transition='opacity .08s ease';levelFlashEl.style.opacity='0.35';
    setTimeout(()=>{levelFlashEl.style.transition='opacity .6s ease';levelFlashEl.style.opacity='0';},80);
    levelUpPopup.innerHTML='LEVEL '+level;
    levelUpPopup.style.color=theme.accent;levelUpPopup.style.textShadow='0 0 30px '+theme.accent+', 0 0 60px '+theme.accent;
    levelUpPopup.classList.remove('show');void levelUpPopup.offsetWidth;levelUpPopup.classList.add('show');
    if(level%3===0){
      const rand=POWERUP_TYPES[Math.floor(Math.random()*POWERUP_TYPES.length)];
      playerData.powerupInventory[rand.id]=(playerData.powerupInventory[rand.id]||0)+1;
    }
  }

  function spawnCoinGain(text,x,y,color){
    const el=document.createElement('div');el.className='coin-gain';el.textContent=text;
    el.style.color=color||'#ffd23f';el.style.left=x+'px';el.style.top=y+'px';
    document.getElementById('wrap').appendChild(el);setTimeout(()=>el.remove(),850);
  }

  // ===== RENDER =====
  function render(){
    ctx.clearRect(0,0,W,H);
    const theme=getRunTheme(currentRunLevel);
    let sx=0,sy=0;
    if(shakeMag>0.3){sx=(Math.random()-0.5)*shakeMag;sy=(Math.random()-0.5)*shakeMag;}
    ctx.save();ctx.translate(sx,sy);

    const grad=ctx.createLinearGradient(0,0,0,H);
    grad.addColorStop(0,theme.top||'#0a0e1f');grad.addColorStop(1,theme.bottom||'#161033');
    ctx.fillStyle=grad;ctx.fillRect(-20,-20,W+40,H+40);

    drawBgEffect(theme);

    for(const o of orbs){
      o.x+=Math.cos(o.dir)*o.speed*0.016;o.y+=Math.sin(o.dir)*o.speed*0.016;
      if(o.x<-o.r)o.x=W+o.r;if(o.x>W+o.r)o.x=-o.r;
      if(o.y<-o.r)o.y=H+o.r;if(o.y>H+o.r)o.y=-o.r;
      const og=ctx.createRadialGradient(o.x,o.y,0,o.x,o.y,o.r);
      og.addColorStop(0,o.color+'22');og.addColorStop(1,o.color+'00');
      ctx.fillStyle=og;ctx.fillRect(o.x-o.r,o.y-o.r,o.r*2,o.r*2);
    }

    ctx.strokeStyle=theme.gridColor||'rgba(77,238,234,0.05)';ctx.lineWidth=1;
    const gSpd=theme.id==='neon'?60:48;
    for(let x=-((performance.now()/30)%gSpd);x<W;x+=gSpd){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}

    const skinColors=activeSkinColor();
    const colA=gravityDir>0?skinColors[0]:skinColors[1];
    const colB=gravityDir>0?skinColors[1]:skinColors[0];
    const rgbA=hexToRgb(colA);

    const topGlow=ctx.createLinearGradient(0,0,0,60);
    topGlow.addColorStop(0,gravityDir<0?`rgba(${hexToRgb(colA)},0.2)`:'rgba(0,0,0,0)');
    topGlow.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=topGlow;ctx.fillRect(0,0,W,60);
    const botGlow=ctx.createLinearGradient(0,H-60,0,H);
    botGlow.addColorStop(0,'rgba(0,0,0,0)');
    botGlow.addColorStop(1,gravityDir>0?`rgba(${hexToRgb(colA)},0.2)`:'rgba(0,0,0,0)');
    ctx.fillStyle=botGlow;ctx.fillRect(0,H-60,W,60);

    drawObstacles(theme);

    for(const c of collectibles){
      const pulse=Math.sin(c.pulse)*0.3+0.7;
      ctx.save();ctx.shadowColor=c.color;ctx.shadowBlur=14*pulse;
      if(c.powerup){
        ctx.font=`${Math.round(c.r*1.6)}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
        ctx.globalAlpha=pulse;ctx.fillText(c.icon||'✨',c.x,c.y);
        ctx.globalAlpha=pulse*0.5;ctx.strokeStyle=c.color;ctx.lineWidth=2;
        ctx.beginPath();ctx.arc(c.x,c.y,c.r*2,0,Math.PI*2);ctx.stroke();
      } else {
        ctx.beginPath();
        const cg=ctx.createRadialGradient(c.x-3,c.y-3,0,c.x,c.y,c.r);
        cg.addColorStop(0,'#fffde0');cg.addColorStop(1,'#ffd23f');
        ctx.fillStyle=cg;ctx.arc(c.x,c.y,c.r*pulse,0,Math.PI*2);ctx.fill();
      }
      ctx.restore();
    }

    for(const p of particles){
      const a=1-p.age/p.life;ctx.globalAlpha=a;ctx.fillStyle=p.color;
      ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    const effectiveR=tinyActive?PLAYER_R*0.55:PLAYER_R;
    ctx.beginPath();
    const trailGrad=ctx.createRadialGradient(player.x,player.y,0,player.x,player.y,effectiveR*4);
    trailGrad.addColorStop(0,`rgba(${rgbA},${ghostActive?0.15:0.4})`);trailGrad.addColorStop(1,`rgba(${rgbA},0)`);
    ctx.fillStyle=trailGrad;ctx.arc(player.x,player.y,effectiveR*4,0,Math.PI*2);ctx.fill();

    if(shieldActive){
      const now=performance.now()/1000;
      const shieldPulse=0.5+0.5*Math.sin(now*6);
      ctx.strokeStyle=`rgba(77,238,234,${0.5+shieldPulse*0.4})`;ctx.lineWidth=3;
      ctx.shadowColor='#4deeea';ctx.shadowBlur=20;
      ctx.beginPath();ctx.arc(player.x,player.y,effectiveR+10+shieldPulse*4,0,Math.PI*2);ctx.stroke();
      ctx.shadowBlur=0;
      // Draw hit counter if > 1
      if(shieldHitsLeft>1){
        ctx.font='bold 10px Archivo Black';ctx.textAlign='center';ctx.textBaseline='middle';
        ctx.fillStyle='#4deeea';ctx.fillText(shieldHitsLeft,player.x,player.y-effectiveR-18);
      }
    }
    if(timewarpActive){
      // Draw time warp rings
      const now=performance.now()/1000;
      for(let r=0;r<3;r++){
        const ringR=effectiveR+15+r*10+Math.sin(now*3+r)*5;
        ctx.strokeStyle=`rgba(124,77,255,${0.2-r*0.05})`;ctx.lineWidth=1.5;
        ctx.beginPath();ctx.arc(player.x,player.y,ringR,0,Math.PI*2);ctx.stroke();
      }
    }

    ctx.beginPath();
    ctx.strokeStyle=ghostActive?'rgba(255,255,255,0.3)':`rgba(${rgbA},0.5)`;ctx.lineWidth=2;
    ctx.arc(player.x,player.y,effectiveR+6,0,Math.PI*2);ctx.stroke();

    ctx.beginPath();ctx.fillStyle=ghostActive?'rgba(255,255,255,0.5)':'#eef0ff';
    ctx.shadowColor=colA;ctx.shadowBlur=28;ctx.globalAlpha=ghostActive?0.6:1;
    ctx.arc(player.x,player.y,effectiveR,0,Math.PI*2);ctx.fill();
    ctx.shadowBlur=0;ctx.globalAlpha=1;

    ctx.beginPath();ctx.fillStyle=colA;ctx.globalAlpha=0.7;
    ctx.arc(player.x-4,player.y-4,effectiveR*0.35,0,Math.PI*2);ctx.fill();ctx.globalAlpha=1;

    ctx.fillStyle=colA;ctx.beginPath();
    const ay=player.y+gravityDir*(effectiveR+10);
    ctx.moveTo(player.x-6,ay-gravityDir*6);ctx.lineTo(player.x+6,ay-gravityDir*6);ctx.lineTo(player.x,ay+gravityDir*4);
    ctx.closePath();ctx.fill();

    // Charge glow around player
    if(tapCharge>0){
      const frac=tapCharge/getChargeTaps();
      const glow=ctx.createRadialGradient(player.x,player.y,effectiveR,player.x,player.y,effectiveR*2.5);
      glow.addColorStop(0,`rgba(179,136,255,${frac*0.5})`);glow.addColorStop(1,'rgba(179,136,255,0)');
      ctx.fillStyle=glow;ctx.beginPath();ctx.arc(player.x,player.y,effectiveR*2.5,0,Math.PI*2);ctx.fill();
    }

    if(activePowerup&&powerupTimer>0){
      const puDef=POWERUP_TYPES.find(p=>p.id===activePowerup);
      const totalDur=puDef?(puDef.duration+getPowerupDurBonus()):5;const frac=Math.max(0,powerupTimer/totalDur);
      const barW=100,barH=5;const bx=player.x-barW/2,by=player.y-effectiveR-22;
      ctx.fillStyle='rgba(0,0,0,0.4)';roundRectPath(bx,by,barW,barH,3);ctx.fill();
      ctx.fillStyle=puDef?puDef.color:'#fff';ctx.shadowColor=puDef?puDef.color:'#fff';ctx.shadowBlur=8;
      roundRectPath(bx,by,barW*frac,barH,3);ctx.fill();ctx.shadowBlur=0;
    }

    // Boss entity on screen
    if(bossData){
      const now=performance.now()/1000;
      const bx=W*0.82;const by=H*0.3+Math.sin(now*2)*30;
      const bColor=bossData.color;
      ctx.save();
      ctx.shadowColor=bColor;ctx.shadowBlur=20;
      ctx.font=`${Math.round(40+Math.sin(now*3)*5)}px serif`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.globalAlpha=0.7+Math.sin(now*4)*0.2;
      ctx.fillText(bossData.icon,bx,by);
      // Boss phase 2 indicator
      if(bossData.currentHp<=bossData.phaseAt){
        ctx.font='8px Archivo Black';ctx.fillStyle=bColor;ctx.globalAlpha=1;
        ctx.fillText('PHASE 2',bx,by+38);
      }
      ctx.globalAlpha=1;ctx.restore();
    }

    ctx.restore();
  }

  function drawBgEffect(theme){
    const now=performance.now()/1000;
    if(theme.bgEffect==='stars'||theme.bgEffect==='minimal'){
      for(const s of stars){
        const tw=0.4+0.6*(0.5+0.5*Math.sin(now*s.speed+s.phase));
        ctx.globalAlpha=tw;ctx.fillStyle=theme.bgEffect==='minimal'?'rgba(255,255,255,0.4)':'#cfe8ff';
        ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fill();
      }
      ctx.globalAlpha=1;
    }
    if(theme.bgEffect==='ember'){
      if(Math.random()<0.3){bgParticles.push({x:Math.random()*W,y:H+5,vx:(Math.random()-0.5)*20,vy:-(30+Math.random()*80),life:2+Math.random()*2,age:0,color:Math.random()<0.5?'#ff5e3a':'#ffd23f',r:1+Math.random()*2});}
      for(let i=bgParticles.length-1;i>=0;i--){
        const p=bgParticles[i];p.age+=0.016;p.x+=p.vx*0.016;p.y+=p.vy*0.016;
        if(p.age>=p.life){bgParticles.splice(i,1);continue;}
        ctx.globalAlpha=(1-p.age/p.life)*0.6;ctx.fillStyle=p.color;
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
      }
      ctx.globalAlpha=1;
    }
    if(theme.bgEffect==='snow'){
      if(Math.random()<0.25){bgParticles.push({x:Math.random()*W,y:-5,vx:(Math.random()-0.5)*15+Math.sin(now)*10,vy:25+Math.random()*40,life:4+Math.random()*3,age:0,color:'#bfefff',r:1+Math.random()*2});}
      for(let i=bgParticles.length-1;i>=0;i--){
        const p=bgParticles[i];p.age+=0.016;p.x+=p.vx*0.016+Math.sin(now+p.age)*0.5;p.y+=p.vy*0.016;
        if(p.age>=p.life||p.y>H+5){bgParticles.splice(i,1);continue;}
        ctx.globalAlpha=(1-p.age/p.life)*0.5;ctx.fillStyle=p.color;
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
      }
      ctx.globalAlpha=1;
    }
    if(theme.bgEffect==='city'){
      ctx.fillStyle='rgba(0,0,0,0.5)';
      if(!theme._cityBuildings){
        theme._cityBuildings=[];
        for(let i=0;i<20;i++){theme._cityBuildings.push({x:i*(W/20)+Math.random()*30-15,w:20+Math.random()*30,h:40+Math.random()*120});}
      }
      for(const b of theme._cityBuildings){
        ctx.fillRect(b.x,H-b.h,b.w,b.h);
        ctx.fillStyle=`rgba(${hexToRgb(theme.accent)},${Math.random()<0.02?'0.9':'0.15'})`;
        for(let wx=b.x+4;wx<b.x+b.w-4;wx+=8){for(let wy=H-b.h+6;wy<H-6;wy+=12){ctx.fillRect(wx,wy,4,6);}}
        ctx.fillStyle='rgba(0,0,0,0.5)';
      }
      const scanY=((now*60)%H);
      ctx.strokeStyle=`rgba(${hexToRgb(theme.accent)},0.06)`;ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(0,scanY);ctx.lineTo(W,scanY);ctx.stroke();
    }
    if(theme.bgEffect==='lightning'){
      if(Math.random()<0.02){
        ctx.strokeStyle='rgba(179,136,255,0.6)';ctx.lineWidth=1.5;ctx.beginPath();
        let lx=Math.random()*W,ly=0;ctx.moveTo(lx,ly);
        while(ly<H){lx+=(Math.random()-0.5)*60;ly+=30+Math.random()*40;ctx.lineTo(lx,ly);}
        ctx.stroke();
      }
    }
    if(theme.bgEffect==='particles'){
      for(const s of stars){
        const tw=0.3+0.4*(0.5+0.5*Math.sin(now*s.speed+s.phase));
        ctx.globalAlpha=tw;ctx.fillStyle=theme.orbColors[0];
        ctx.beginPath();ctx.arc(s.x,s.y,s.r*0.8,0,Math.PI*2);ctx.fill();
      }
      ctx.globalAlpha=1;
    }
  }

  function drawObstacles(theme){
    const wallColor=theme.wallColor||'#1a1438';
    const wallGlow=theme.wallGlow||'#7c4dff';
    const gapGlow=theme.gapGlow||'#ffd23f';
    const style=theme.obstacleStyle||'pillar';

    for(const o of obstacles){
      const gapTop=o.gapY-o.gapH/2;const gapBot=o.gapY+o.gapH/2;
      const oStyle=o.bossWall?'electric':(o.style||style);
      ctx.save();ctx.shadowColor=o.bossWall?'#ff3caf':wallGlow;ctx.shadowBlur=o.bossWall?28:18;

      if(oStyle==='neon'){
        ctx.strokeStyle=wallGlow;ctx.lineWidth=3;ctx.fillStyle=wallColor+'cc';
        roundRectPath(o.x,-10,o.width,gapTop+10,6);ctx.fill();ctx.stroke();
        roundRectPath(o.x,gapBot,o.width,H-gapBot+10,6);ctx.fill();ctx.stroke();
        ctx.shadowBlur=30;ctx.strokeStyle=theme.accent+'88';ctx.lineWidth=1;
        roundRectPath(o.x+2,-10,o.width-4,gapTop+10,5);ctx.stroke();
        roundRectPath(o.x+2,gapBot,o.width-4,H-gapBot+10,5);ctx.stroke();
      } else if(oStyle==='ice'){
        const iceGrad=ctx.createLinearGradient(o.x,0,o.x+o.width,0);
        iceGrad.addColorStop(0,'#001a2e');iceGrad.addColorStop(0.5,'#002a40');iceGrad.addColorStop(1,'#001a2e');
        ctx.fillStyle=iceGrad;ctx.strokeStyle='rgba(191,239,255,0.7)';ctx.lineWidth=2;
        roundRectPath(o.x,-10,o.width,gapTop+10,6);ctx.fill();ctx.stroke();
        roundRectPath(o.x,gapBot,o.width,H-gapBot+10,6);ctx.fill();ctx.stroke();
      } else if(oStyle==='cracked'){
        const crackGrad=ctx.createLinearGradient(o.x,0,o.x+o.width,0);
        crackGrad.addColorStop(0,wallColor);crackGrad.addColorStop(1,'#1a0500');
        ctx.fillStyle=crackGrad;ctx.strokeStyle=wallGlow+'aa';ctx.lineWidth=2;
        roundRectPath(o.x,-10,o.width,gapTop+10,4);ctx.fill();ctx.stroke();
        roundRectPath(o.x,gapBot,o.width,H-gapBot+10,4);ctx.fill();ctx.stroke();
        ctx.strokeStyle='#ff3c0088';ctx.lineWidth=1.5;ctx.beginPath();
        ctx.moveTo(o.x+o.width/2,-5);ctx.quadraticCurveTo(o.x+o.width*0.8,gapTop*0.5,o.x+o.width*0.3,gapTop+5);ctx.stroke();
      } else if(oStyle==='drip'){
        ctx.fillStyle=wallColor;ctx.strokeStyle=wallGlow+'cc';ctx.lineWidth=2;
        roundRectPath(o.x,-10,o.width,gapTop+10,4);ctx.fill();ctx.stroke();
        roundRectPath(o.x,gapBot,o.width,H-gapBot+10,4);ctx.fill();ctx.stroke();
        for(let d=0;d<3;d++){
          const dx=o.x+5+d*7;const dLen=10+d*8+Math.sin(performance.now()/300+d)*5;
          ctx.fillStyle=wallGlow+'cc';ctx.beginPath();ctx.ellipse(dx,gapTop+dLen,3,dLen,0,0,Math.PI*2);ctx.fill();
        }
      } else if(oStyle==='electric'){
        const eGrad=ctx.createLinearGradient(o.x,0,o.x+o.width,0);
        eGrad.addColorStop(0,'#0d0521');eGrad.addColorStop(1,'#1f0a3d');
        ctx.fillStyle=o.bossWall?'#1a000a':eGrad;ctx.strokeStyle=o.bossWall?'#ff3caf':wallGlow;ctx.lineWidth=2;
        roundRectPath(o.x,-10,o.width,gapTop+10,6);ctx.fill();ctx.stroke();
        roundRectPath(o.x,gapBot,o.width,H-gapBot+10,6);ctx.fill();ctx.stroke();
        if(Math.random()<0.3){
          const sy=Math.random()<0.5?gapTop:gapBot;ctx.strokeStyle=(o.bossWall?'#ff3cafff':wallGlow+'ff');ctx.lineWidth=1;
          ctx.beginPath();ctx.moveTo(o.x,sy);ctx.lineTo(o.x+(Math.random()-0.5)*20,sy+(Math.random()-0.5)*20);ctx.stroke();
        }
      } else {
        const wallGrad=ctx.createLinearGradient(o.x,0,o.x+o.width,0);
        wallGrad.addColorStop(0,wallColor);wallGrad.addColorStop(1,'#1a1438');
        ctx.fillStyle=wallGrad;ctx.strokeStyle=wallGlow+'88';ctx.lineWidth=2;
        roundRectPath(o.x,-10,o.width,gapTop+10,6);ctx.fill();ctx.stroke();
        roundRectPath(o.x,gapBot,o.width,H-gapBot+10,6);ctx.fill();ctx.stroke();
      }

      // Moving indicator arrows
      if(o.moving){
        ctx.fillStyle='rgba(255,255,255,0.5)';ctx.font='10px Arial';ctx.textAlign='center';
        ctx.fillText(o.moveDir>0?'▼':'▲',o.x+o.width/2,o.gapY);
      }

      ctx.shadowBlur=0;
      const gGlow=o.bossWall?'#ff3caf':gapGlow;
      ctx.shadowColor=gGlow;ctx.shadowBlur=14;ctx.fillStyle=gGlow;
      ctx.fillRect(o.x,gapTop-2,o.width,3);ctx.fillRect(o.x,gapBot-1,o.width,3);
      ctx.shadowBlur=0;
      ctx.restore();
    }
  }

  // ===== IDLE RENDER =====
  function idleRender(){
    if(state!=='start')return;
    ctx.clearRect(0,0,W,H);
    const bg=activeBg();
    const grad=ctx.createLinearGradient(0,0,0,H);
    grad.addColorStop(0,bg.top);grad.addColorStop(1,bg.bottom);
    ctx.fillStyle=grad;ctx.fillRect(0,0,W,H);
    const now=performance.now()/1000;

    for(const o of orbs){
      o.x+=Math.cos(o.dir)*o.speed*0.016;o.y+=Math.sin(o.dir)*o.speed*0.016;
      if(o.x<-o.r)o.x=W+o.r;if(o.x>W+o.r)o.x=-o.r;
      if(o.y<-o.r)o.y=H+o.r;if(o.y>H+o.r)o.y=-o.r;
      const og=ctx.createRadialGradient(o.x,o.y,0,o.x,o.y,o.r);
      og.addColorStop(0,o.color+'22');og.addColorStop(1,o.color+'00');
      ctx.fillStyle=og;ctx.fillRect(o.x-o.r,o.y-o.r,o.r*2,o.r*2);
    }

    for(const s of stars){
      const tw=0.4+0.6*(0.5+0.5*Math.sin(now*s.speed+s.phase));
      ctx.globalAlpha=tw;ctx.fillStyle='#cfe8ff';
      ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    ctx.strokeStyle='rgba(77,238,234,0.05)';const gridSize=48;
    for(let x=-((performance.now()/30)%gridSize);x<W;x+=gridSize){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}

    const cy=H/2+Math.sin(performance.now()/700)*55;
    const skinColors2=activeSkinColor();
    const flicker=Math.sin(performance.now()/700)>=0?1:-1;
    const glowColor=flicker>0?skinColors2[0]:skinColors2[1];
    const tc=hexToRgb(glowColor);

    ctx.beginPath();
    const tg=ctx.createRadialGradient(W*PLAYER_X_RATIO,cy,0,W*PLAYER_X_RATIO,cy,PLAYER_R*4);
    tg.addColorStop(0,`rgba(${tc},0.35)`);tg.addColorStop(1,`rgba(${tc},0)`);
    ctx.fillStyle=tg;ctx.arc(W*PLAYER_X_RATIO,cy,PLAYER_R*4,0,Math.PI*2);ctx.fill();

    ctx.beginPath();ctx.fillStyle='#eef0ff';ctx.shadowColor=glowColor;ctx.shadowBlur=28;
    ctx.arc(W*PLAYER_X_RATIO,cy,PLAYER_R,0,Math.PI*2);ctx.fill();ctx.shadowBlur=0;

    const obsX=W*0.65+Math.sin(performance.now()/2000)*20;
    ctx.fillStyle='rgba(255,255,255,0.05)';ctx.strokeStyle='rgba(255,255,255,0.1)';ctx.lineWidth=2;
    roundRectPath(obsX,-10,22,H/3+10,6);ctx.fill();ctx.stroke();
    roundRectPath(obsX,H*0.55,22,H/3+10,6);ctx.fill();ctx.stroke();

    requestAnimationFrame(idleRender);
  }

