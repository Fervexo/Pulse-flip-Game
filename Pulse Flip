  // ===== ACHIEVEMENTS =====
  function checkAchievements(){
    let newUnlocked=false;
    for(const ach of ACHIEVEMENTS){
      if(!playerData.achievements.includes(ach.id)&&ach.req(playerData.stats)){
        playerData.achievements.push(ach.id);
        playerData.coins+=50;
        playerData.stats.totalCoinsEarned+=50;
        newUnlocked=true;
        setTimeout(()=>showMilestone(ach.icon,ach.name,ach.desc+' +50 coins!'),500);
      }
    }
    if(newUnlocked)savePlayerData();
  }

  // ===== LEVEL NAV =====
  function getLevelThemePreviewSVG(lvl){
    const theme=lvl<=1?{id:'space',accent:'#4deeea',top:'#0a0e1f',bottom:'#161033'}:LEVEL_THEMES[(lvl-2)%LEVEL_THEMES.length];
    const id=theme.id;const ac=theme.accent||'#4deeea';const t=theme.top||'#0a0e1f';const b=theme.bottom||'#161033';
    const inner=`<circle cx="28" cy="14" r="10" fill="${ac}" opacity=".8"/>`;
    return `<svg viewBox="0 0 56 30" xmlns="http://www.w3.org/2000/svg" width="52" height="28" style="border-radius:8px;display:block;">
      <defs><linearGradient id="bg${lvl}" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="${t}"/><stop offset="100%" stop-color="${b}"/></linearGradient></defs>
      <rect width="56" height="30" fill="url(#bg${lvl})" rx="6"/>${inner}</svg>`;
  }
  function buildLevelNav(){
    levelNavScroll.innerHTML='';
    const maxLevel=Math.max(playerData.highestLevel||1,1);
    for(let lvl=1;lvl<=maxLevel;lvl++){
      const item=document.createElement('div');
      const isCurrent=(lvl===selectedStartLevel);
      item.className='level-nav-item'+(isCurrent?' current-level':'');
      item.innerHTML=`${getLevelThemePreviewSVG(lvl)}<div class="level-nav-num">Lv.${lvl}</div><div class="level-nav-label">${lvl===1?'Start':LEVEL_THEMES[(lvl-2)%LEVEL_THEMES.length]?.name||'?'}</div>`;
      item.style.borderColor=isCurrent?getLevelColor(lvl):'rgba(255,255,255,0.1)';
      if(isCurrent)item.style.boxShadow=`0 0 12px ${getLevelColor(lvl)}55`;
      item.addEventListener('click',e=>{e.stopPropagation();selectStartLevel(lvl);sfxClick();});
      levelNavScroll.appendChild(item);
    }
    const panel=document.getElementById('levelNavPanel');
    if(maxLevel>1){
      panel.style.display='flex';
      selectedLevelContainer.style.display='flex';
      selectedLevelBadge.textContent=`Starting from Level ${selectedStartLevel}`;
    } else {
      panel.style.display='none';
      selectedLevelContainer.style.display='none';
    }
    setTimeout(()=>{
      const idx=selectedStartLevel-1;
      const el=levelNavScroll.children[idx];
      if(el)el.scrollIntoView({inline:'center',behavior:'smooth'});
    },100);
  }
  function selectStartLevel(lvl){
    selectedStartLevel=lvl;
    playerData.startFromLevel=lvl;
    savePlayerData();
    buildLevelNav();
    const lColor=getLevelColor(lvl);
    selectedLevelBadge.textContent=`Starting from Level ${lvl}`;
    selectedLevelBadge.style.color=lColor;
  }

  // ===== DAILY CHALLENGE =====
  function checkDailyChallenge(){
    const today=new Date().toISOString().slice(0,10);
    if(playerData.dailyChallenge.date!==today){
      const targetBase=Math.max(5,Math.floor(best*0.7)+Math.floor(Math.random()*10)+5);
      playerData.dailyChallenge={date:today,score:0,target:targetBase,done:false};
      savePlayerData();
    }
    const dc=playerData.dailyChallenge;
    dailyChallengeBtn.className='daily-pill'+(dc.done?' done':'');
    dailyChallengeBtn.innerHTML=dc.done?`✅ DAILY DONE: ${dc.score}/${dc.target}`:`⚡ DAILY: SCORE ${dc.target}`;
  }

  // ===== DAILY REWARD =====
  function checkDailyReward(){
    const today=new Date().toISOString().slice(0,10);
    const dr=playerData.dailyReward;
    if(dr.lastDate===today)return;
    const yesterday=new Date(Date.now()-86400000).toISOString().slice(0,10);
    if(dr.lastDate===yesterday){dr.streak=Math.min((dr.streak||0)+1,7);}
    else if(dr.lastDate!==today){dr.streak=1;}
    dr.claimed=false;
    showDailyReward();
  }
  function showDailyReward(){
    const dr=playerData.dailyReward;
    const streak=dr.streak||1;
    const rewardDay=((streak-1)%7);
    const reward=DAILY_REWARDS[rewardDay];
    dailyStreakRow.innerHTML='';
    for(let i=0;i<7;i++){
      const dot=document.createElement('div');
      dot.className='streak-dot'+(i<rewardDay?' done':(i===rewardDay?' today':''));
      dot.textContent=i<rewardDay?'✓':(i===rewardDay?'★':(i+1));
      dailyStreakRow.appendChild(dot);
    }
    dailyRewardItems.innerHTML=`
      <div class="daily-reward-item">
        <div class="daily-reward-icon">${reward.icon}</div>
        <div class="daily-reward-info">
          <div class="daily-reward-name">${reward.name}</div>
          <div class="daily-reward-desc">Day ${rewardDay+1} Streak Reward</div>
        </div>
      </div>
      ${streak>=7?`<div class="daily-reward-item"><div class="daily-reward-icon">🎁</div><div class="daily-reward-info"><div class="daily-reward-name">Bonus Bundle</div><div class="daily-reward-desc">7-Day Streak Bonus</div></div></div>`:''}`;
    dailyRewardPopup.classList.remove('hidden');
  }
  claimRewardBtn.addEventListener('click',e=>{
    e.stopPropagation();unlockAudio();sfxClaim();
    const today=new Date().toISOString().slice(0,10);
    const dr=playerData.dailyReward;
    const streak=dr.streak||1;
    const rewardDay=((streak-1)%7);
    const reward=DAILY_REWARDS[rewardDay];
    if(reward.type==='coins'){playerData.coins+=reward.amount;playerData.stats.totalCoinsEarned+=reward.amount;}
    else if(reward.type==='powerup'){playerData.powerupInventory[reward.pid]=(playerData.powerupInventory[reward.pid]||0)+reward.amount;}
    if(streak>=7&&streak%7===0){
      playerData.coins+=200;playerData.stats.totalCoinsEarned+=200;
      POWERUP_TYPES.forEach(pt=>{playerData.powerupInventory[pt.id]=(playerData.powerupInventory[pt.id]||0)+2;});
    }
    dr.lastDate=today;dr.claimed=true;
    updateCoinDisplays();savePlayerData();
    dailyRewardPopup.classList.add('hidden');
    showMilestone(reward.icon,'DAILY REWARD',`+${reward.name} claimed!`);
  });

  // ===== QUESTS UI =====
  function openQuests(){
    sfxClick();
    questsList.innerHTML='';
    QUESTS.forEach(q=>{
      const done=playerData.questCompleted[q.id]||false;
      const prog=Math.min(playerData.questProgress[q.id]||0,q.target);
      const card=document.createElement('div');
      card.className='quest-card'+(done?' done':'');
      card.innerHTML=`
        <div class="quest-icon">${q.icon}</div>
        <div class="quest-info">
          <div class="quest-name">${q.name}${q.mode?` <span style="font-size:8px;color:var(--muted);letter-spacing:1px;">[${q.mode}]</span>`:''}</div>
          <div class="quest-prog">${q.desc}</div>
          <div class="quest-bar-wrap"><div class="quest-bar-fill" style="width:${done?100:Math.floor(prog/q.target*100)}%"></div></div>
          <div class="quest-prog" style="margin-top:3px;">${done?'✓ DONE':prog+'/'+q.target}</div>
        </div>
        <div class="quest-reward">+${q.reward}<span class="coin-icon" style="display:inline-block;width:10px;height:10px;border-radius:50%;background:radial-gradient(circle at 32% 32%,#fffbe0,var(--amber) 70%);vertical-align:middle;margin-left:2px;"></span></div>`;
      questsList.appendChild(card);
    });
    questsOverlay.classList.remove('hidden');
  }

  // ===== UPGRADES UI =====
  function openUpgrades(){
    sfxClick();
    upgradesCoinsEl.textContent=playerData.coins;
    upgradesList.innerHTML='';
    UPGRADES.forEach(upg=>{
      const lvl=getUpgradeLevel(upg.id);
      const maxed=lvl>=upg.maxLevel;
      const cost=maxed?0:upg.costs[lvl];
      const canAfford=playerData.coins>=cost;
      const card=document.createElement('div');
      card.className='upgrade-card';
      const pips=Array.from({length:upg.maxLevel},(_,i)=>`<div class="upgrade-pip${i<lvl?' filled':''}"></div>`).join('');
      card.innerHTML=`
        <div class="upgrade-icon">${upg.icon}</div>
        <div class="upgrade-info">
          <div class="upgrade-name">${upg.name} ${lvl>0?'(Lv.'+lvl+')':''}</div>
          <div class="upgrade-desc">${upg.effect}</div>
          <div class="upgrade-level-pips">${pips}</div>
        </div>
        ${maxed?`<div class="upgrade-maxed">MAX</div>`:`<button class="upgrade-buy" data-id="${upg.id}" ${canAfford?'':'disabled'}><span class="coin-icon" style="display:inline-block;width:10px;height:10px;border-radius:50%;background:radial-gradient(circle at 32% 32%,#fffbe0,var(--amber) 70%);vertical-align:middle;margin-right:3px;"></span>${cost}</button>`}`;
      upgradesList.appendChild(card);
    });
    upgradesOverlay.classList.remove('hidden');
  }

  upgradesList.addEventListener('click',e=>{
    const btn=e.target.closest('.upgrade-buy');if(!btn)return;
    e.stopPropagation();
    const id=btn.dataset.id;
    const upg=UPGRADES.find(u=>u.id===id);if(!upg)return;
    const lvl=getUpgradeLevel(id);
    if(lvl>=upg.maxLevel)return;
    const cost=upg.costs[lvl];
    if(playerData.coins<cost)return;
    playerData.coins-=cost;
    playerData.stats.totalSpent+=cost;
    playerData.upgradeLevel[id]=(playerData.upgradeLevel[id]||0)+1;
    sfxBuy();
    updateCoinDisplays();
    savePlayerData();
    checkAchievements();
    openUpgrades();// re-render
  });

  // ===== STATS =====
  function openStats(){
    sfxClick();
    const st=playerData.stats;const rank=getRank(best);
    const plvl=st.playerLevel||1;
    statsGrid.innerHTML=`
      <div class="stat-card"><div class="stat-value">${best}</div><div class="stat-label">Best Score</div></div>
      <div class="stat-card"><div class="stat-value">${st.totalRuns}</div><div class="stat-label">Total Runs</div></div>
      <div class="stat-card"><div class="stat-value">${st.totalFlips}</div><div class="stat-label">Total Flips</div></div>
      <div class="stat-card" style="border-color:${rank.color}44;"><div class="stat-value" style="color:${rank.color}">${rank.name}</div><div class="stat-label">Rank</div></div>
      <div class="stat-card"><div class="stat-value">${Math.floor(st.longestRun)}s</div><div class="stat-label">Longest Run</div></div>
      <div class="stat-card"><div class="stat-value">${st.maxLevelReached}</div><div class="stat-label">Max Level</div></div>
      <div class="stat-card"><div class="stat-value">${st.totalCoinsEarned}</div><div class="stat-label">Coins Earned</div></div>
      <div class="stat-card"><div class="stat-value">${st.maxStreak}x</div><div class="stat-label">Best Streak</div></div>
      <div class="stat-card"><div class="stat-value">${st.totalSuperFlips||0}</div><div class="stat-label">Super Flips</div></div>
      <div class="stat-card"><div class="stat-value">${st.bossesDefeated||0}</div><div class="stat-label">Bosses Killed</div></div>
      <div class="stat-card"><div class="stat-value">${st.questsCompleted||0}</div><div class="stat-label">Quests Done</div></div>
      <div class="stat-card" style="border-color:rgba(179,136,255,0.4);"><div class="stat-value" style="color:var(--purple)">Lv.${plvl}</div><div class="stat-label">Player Level</div></div>
    `;
    achievementsGrid.innerHTML='<div class="achievements-title">Achievements ('+playerData.achievements.length+'/'+ACHIEVEMENTS.length+')</div>';
    ACHIEVEMENTS.forEach(ach=>{
      const unlocked=playerData.achievements.includes(ach.id);
      const row=document.createElement('div');
      row.className='achievement-row'+(unlocked?' unlocked':'');
      row.innerHTML=`<div class="ach-icon">${ach.icon}</div><div class="ach-info"><div class="ach-name" style="${unlocked?'color:var(--amber)':''}">${ach.name}</div><div class="ach-desc">${ach.desc}</div></div><div class="ach-locked">${unlocked?'✓':''}</div>`;
      achievementsGrid.appendChild(row);
    });
    statsOverlay.classList.remove('hidden');
  }

  statsBtnStart.addEventListener('click',e=>{e.stopPropagation();openStats();});
  statsCloseBtn.addEventListener('click',e=>{e.stopPropagation();sfxClick();statsOverlay.classList.add('hidden');});
  questsBtnStart.addEventListener('click',e=>{e.stopPropagation();openQuests();});
  questsCloseBtn.addEventListener('click',e=>{e.stopPropagation();sfxClick();questsOverlay.classList.add('hidden');});
  upgradesBtnStart.addEventListener('click',e=>{e.stopPropagation();openUpgrades();});
  upgradesCloseBtn.addEventListener('click',e=>{e.stopPropagation();sfxClick();upgradesOverlay.classList.add('hidden');});

  // ===== INPUT =====
  function onTap(e){
    if(!shopOverlay.classList.contains('hidden'))return;
    if(!statsOverlay.classList.contains('hidden'))return;
    if(!dailyRewardPopup.classList.contains('hidden'))return;
    if(!questsOverlay.classList.contains('hidden'))return;
    if(!upgradesOverlay.classList.contains('hidden'))return;
    if(state!=='playing')return;
    if(e&&e.target.closest('.pu-slot'))return;
    if(e)e.preventDefault();
    unlockAudio();flip();
  }
  window.addEventListener('pointerdown',onTap);
  window.addEventListener('keydown',e=>{if(e.code==='Space'&&state==='playing')onTap();});

  startBtn.addEventListener('click',e=>{e.stopPropagation();sfxClick();startGame();});
  retryBtn.addEventListener('click',e=>{e.stopPropagation();sfxClick();startGame();});
  homeBtn.addEventListener('click',e=>{
    e.stopPropagation();sfxClick();
    overScreen.classList.add('hidden');
    updateLobby();buildLevelNav();buildModeSelect();state='start';
    startScreen.classList.remove('hidden');
    requestAnimationFrame(idleRender);
  });
  soundBtn.addEventListener('click',e=>{
    e.stopPropagation();
    playerData.settings.muted=!playerData.settings.muted;
    updateSoundBtn();savePlayerData();
    if(!playerData.settings.muted){unlockAudio();sfxClick();}
  });
  shareBtn.addEventListener('click',e=>{
    e.stopPropagation();sfxClick();
    const mode=GAME_MODES.find(m=>m.id===currentMode)||GAME_MODES[0];
    const text=`I scored ${score} in PULSE FLIP [${mode.name} Mode]! Reached Level ${currentRunLevel}. 4-tap charge. Super flips. Don't get spiked. Can you beat it?`;
    if(navigator.share){navigator.share({text}).catch(()=>{});}
    else if(navigator.clipboard){navigator.clipboard.writeText(text).then(()=>{shareBtn.textContent='Copied!';setTimeout(()=>{shareBtn.textContent='Share';},1200);}).catch(()=>{});}
  });
  dailyChallengeBtn.addEventListener('click',e=>{e.stopPropagation();sfxClick();startGame();});

  // ===== SHOP =====
  let shopTab='skins';
  const SHOP_CFG={
    skins:{items:SKINS,ownedKey:'skins',equipKey:'skin'},
    trails:{items:TRAILS,ownedKey:'trails',equipKey:'trail'},
    backgrounds:{items:BACKGROUNDS,ownedKey:'backgrounds',equipKey:'background'},
    powerups:{items:POWERUP_SHOP,ownedKey:null,equipKey:null}
  };
  function previewHTML(tab,item){
    if(tab==='skins'){
      const[c0,c1]=item.colors;
      if(item.prism)return `<div class="preview-orb" style="background:conic-gradient(#ff3caf,#ffd23f,#4deeea,#7c4dff,#ff3caf);box-shadow:0 0 22px rgba(77,238,234,0.6);"></div>`;
      return `<div class="preview-orb" style="background:radial-gradient(circle at 30% 30%,#ffffff,${c0} 55%);box-shadow:0 0 18px ${c0}aa,inset -8px -8px 14px ${c1}99;"></div>`;
    }
    if(tab==='trails'){
      if(item.rainbow)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#ff3caf,#ffd23f,#4deeea,#7c4dff,#ff3caf);box-shadow:0 0 14px rgba(255,255,255,0.35);"></div>`;
      if(item.ghost)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,rgba(255,255,255,0.8),rgba(170,170,170,0.4));box-shadow:0 0 10px rgba(255,255,255,0.3);"></div>`;
      if(item.fire)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#ff1a00,#ff7a3c);box-shadow:0 0 14px rgba(255,94,58,0.6);"></div>`;
      if(item.ice)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#4d9fff,#bfefff);box-shadow:0 0 14px rgba(77,153,255,0.5);"></div>`;
      if(item.dark)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#0d0521,#7c4dff);box-shadow:0 0 14px rgba(124,77,255,0.6);"></div>`;
      if(item.sparkle)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#ffd23f,#fffbe0);box-shadow:0 0 14px rgba(255,210,63,0.7);"></div>`;
      if(item.lava)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#ff3c00,#ffaa00);box-shadow:0 0 14px rgba(255,60,0,0.6);"></div>`;
      if(item.electric)return `<div style="width:56px;height:12px;border-radius:8px;background:linear-gradient(90deg,#b388ff,#4deeea);box-shadow:0 0 14px rgba(179,136,255,0.7);"></div>`;
      const[c0,c1]=item.colors||['#fff','#aaa'];
      return `<div class="preview-trail"><span style="width:10px;height:10px;background:${c0};box-shadow:0 0 8px ${c0};border-radius:50%;"></span><span style="width:7px;height:7px;background:${c1};opacity:0.85;border-radius:50%;"></span><span style="width:5px;height:5px;background:${c0};opacity:0.5;border-radius:50%;"></span></div>`;
    }
    if(tab==='backgrounds'){
      const oc=item.orbColors;
      return `<div class="preview-bg" style="background:linear-gradient(180deg,${item.top},${item.bottom});">
        <span style="width:30px;height:30px;background:${oc[0]};opacity:0.35;left:4px;top:2px;"></span>
        <span style="width:22px;height:22px;background:${oc[1]};opacity:0.35;right:6px;top:10px;"></span>
      </div>`;
    }
    if(tab==='powerups'){
      const def=POWERUP_TYPES.find(p=>p.id===item.type);
      const icon=item.ultrabundle?'💎':item.bundle?'🎁':(def?def.icon:'⚡');
      const color=def?def.color:(item.ultrabundle?'#4deeea':'#ffd23f');
      return `<div style="width:48px;height:48px;border-radius:12px;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid ${color}44;">${icon}</div>`;
    }
  }
  function renderShop(){
    const cfg=SHOP_CFG[shopTab];
    shopCoinsEl.textContent=playerData.coins;
    if(shopTab==='powerups'){
      shopGrid.innerHTML=POWERUP_SHOP.map(item=>`
        <div class="shop-item">
          ${previewHTML('powerups',item)}
          <div class="shop-name">${item.name}</div>
          <div style="font-size:9px;color:var(--muted);letter-spacing:1px;margin-bottom:2px;">${item.desc}</div>
          <button class="shop-action buy" data-action="buypowerup" data-id="${item.id}" ${playerData.coins>=item.price?'':'disabled'}>
            <span class="coin-icon" style="display:inline-block;width:10px;height:10px;vertical-align:middle;margin-right:4px;border-radius:50%;background:radial-gradient(circle at 32% 32%,#fffbe0,var(--amber) 70%);"></span>${item.price}
          </button>
        </div>`).join('');
      return;
    }
    shopGrid.innerHTML=cfg.items.map(item=>{
      const owned=item.price===0||playerData.owned[cfg.ownedKey].includes(item.id);
      const equipped=playerData.equipped[cfg.equipKey]===item.id;
      let actionHTML;
      if(equipped){actionHTML=`<div class="shop-action equipped-label">Equipped</div>`;}
      else if(owned){actionHTML=`<button class="shop-action equip" data-action="equip" data-id="${item.id}">Equip</button>`;}
      else{
        const afford=playerData.coins>=item.price;
        actionHTML=`<button class="shop-action buy" data-action="buy" data-id="${item.id}" ${afford?'':'disabled'}>
          <span class="coin-icon" style="display:inline-block;width:10px;height:10px;vertical-align:middle;margin-right:4px;border-radius:50%;background:radial-gradient(circle at 32% 32%,#fffbe0,var(--amber) 70%);"></span>${item.price}
        </button>`;
      }
      return `<div class="shop-item ${equipped?'equipped':''}">
        ${previewHTML(shopTab,item)}
        <div class="shop-name">${item.name}</div>
        ${actionHTML}
      </div>`;
    }).join('');
  }
  shopGrid.addEventListener('click',e=>{
    const btn=e.target.closest('.shop-action');if(!btn)return;
    e.stopPropagation();
    const id=btn.dataset.id,action=btn.dataset.action;
    if(action==='buypowerup'){
      const item=POWERUP_SHOP.find(p=>p.id===id);if(!item||playerData.coins<item.price)return;
      playerData.coins-=item.price;playerData.stats.totalSpent+=item.price;
      if(item.ultrabundle){POWERUP_TYPES.forEach(pt=>{playerData.powerupInventory[pt.id]=(playerData.powerupInventory[pt.id]||0)+10;});}
      else if(item.bundle){POWERUP_TYPES.forEach(pt=>{playerData.powerupInventory[pt.id]=(playerData.powerupInventory[pt.id]||0)+5;});}
      else{playerData.powerupInventory[item.type]=(playerData.powerupInventory[item.type]||0)+item.count;}
      sfxBuy();updateCoinDisplays();savePlayerData();renderShop();checkAchievements();return;
    }
    const cfg=SHOP_CFG[shopTab];const item=cfg.items.find(i=>i.id===id);if(!item)return;
    if(action==='buy'&&playerData.coins>=item.price){
      playerData.coins-=item.price;playerData.stats.totalSpent+=item.price;
      playerData.owned[cfg.ownedKey].push(id);playerData.equipped[cfg.equipKey]=id;
      sfxBuy();updateCoinDisplays();savePlayerData();
      if(shopTab==='backgrounds')genBackground();
      checkAchievements();renderShop();
    } else if(action==='equip'){
      playerData.equipped[cfg.equipKey]=id;sfxClick();savePlayerData();
      if(shopTab==='backgrounds')genBackground();renderShop();
    }
  });
  function openShop(){unlockAudio();sfxClick();shopOverlay.classList.remove('hidden');renderShop();}
  function closeShop(){sfxClick();shopOverlay.classList.add('hidden');}
  shopBtnStart.addEventListener('click',e=>{e.stopPropagation();openShop();});
  shopBtnOver.addEventListener('click',e=>{e.stopPropagation();openShop();});
  shopClose.addEventListener('click',e=>{e.stopPropagation();closeShop();});
  shopTabs.forEach(tab=>{
    tab.addEventListener('click',e=>{
      e.stopPropagation();sfxClick();
      shopTabs.forEach(t=>t.classList.remove('active'));tab.classList.add('active');
      shopTab=tab.dataset.tab;renderShop();
    });
  });

  // ===== HELPERS =====
  function hexToRgb(hex){
    if(!hex||hex[0]!=='#')return '255,255,255';
    hex=hex.replace('#','');
    if(hex.length===3)hex=hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
    return `${parseInt(hex.substring(0,2),16)},${parseInt(hex.substring(2,4),16)},${parseInt(hex.substring(4,6),16)}`;
  }
  function roundRectPath(x,y,w,h,r){
    if(h<=0){ctx.beginPath();return;}
    r=Math.min(r,w/2,Math.abs(h)/2);
    ctx.beginPath();ctx.moveTo(x+r,y);ctx.arcTo(x+w,y,x+w,y+h,r);ctx.arcTo(x+w,y+h,x,y+h,r);ctx.arcTo(x,y+h,x,y,r);ctx.arcTo(x,y,x+w,y,r);ctx.closePath();
  }

  // ===== BOOT =====
  loadPlayerData();
  requestAnimationFrame(idleRender);
})();
</script>
