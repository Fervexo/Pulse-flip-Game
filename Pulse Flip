  // ===== AUDIO =====
  let audioCtx=null;
  function getAudioCtx(){
    if(!audioCtx){const AC=window.AudioContext||window.webkitAudioContext;if(!AC)return null;audioCtx=new AC();}
    if(audioCtx.state==='suspended')audioCtx.resume();
    return audioCtx;
  }
  function unlockAudio(){getAudioCtx();}
  function playTone(freq,dur,type,vol,freqEnd){
    if(playerData.settings.muted)return;
    const ac=getAudioCtx();if(!ac)return;
    const osc=ac.createOscillator();const gain=ac.createGain();
    osc.type=type||'sine';osc.frequency.setValueAtTime(freq,ac.currentTime);
    if(freqEnd)osc.frequency.exponentialRampToValueAtTime(freqEnd,ac.currentTime+dur);
    gain.gain.setValueAtTime(vol!=null?vol:0.2,ac.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.0001,ac.currentTime+dur);
    osc.connect(gain);gain.connect(ac.destination);osc.start();osc.stop(ac.currentTime+dur);
  }
  function sfxFlip(){playTone(420,0.09,'square',0.13,720);}
  function sfxSuperFlip(){
    playTone(220,0.05,'sawtooth',0.2,880);
    setTimeout(()=>playTone(880,0.05,'sine',0.22,1760),50);
    setTimeout(()=>playTone(1760,0.2,'sine',0.2,440),100);
