.powerup-hud{position:absolute;bottom:max(18px,env(safe-area-inset-bottom));left:50%;transform:translateX(-50%);display:none;gap:8px;align-items:center;z-index:6;pointer-events:auto;}
.powerup-hud.active{display:flex;}
.pu-slot{width:44px;height:44px;border-radius:12px;background:rgba(10,14,31,0.75);border:1.5px solid rgba(255,255,255,0.12);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(4px);position:relative;transition:transform .1s ease,border-color .15s ease;}
