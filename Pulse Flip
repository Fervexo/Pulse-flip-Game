.pu-slot.empty{opacity:0.4;cursor:default;}
.pu-slot .pu-icon{font-size:20px;line-height:1;}
.pu-slot .pu-count{position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;background:var(--amber);color:#0a0e1f;font-size:9px;font-weight:900;display:flex;align-items:center;justify-content:center;border:1px solid #0a0e1f;}
.pu-slot .pu-active-bar{position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 10px 10px;transition:width .1s linear;}
.streak-badge{position:absolute;bottom:max(18px,env(safe-area-inset-bottom));left:14px;z-index:6;display:none;align-items:center;gap:5px;background:rgba(255,210,63,0.12);border:1px solid rgba(255,210,63,0.4);border-radius:100px;padding:5px 12px;font-size:11px;font-weight:700;letter-spacing:2px;color:var(--amber);pointer-events:none;}
.streak-badge.show{display:flex;}
.hint-bar{position:absolute;bottom:max(58px,calc(env(safe-area-inset-bottom)+48px));left:50%;transform:translateX(-50%);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.4);pointer-events:none;z-index:5;white-space:nowrap;animation:hintFade 4s ease forwards;}
@keyframes hintFade{0%{opacity:0;}10%{opacity:1;}80%{opacity:1;}100%{opacity:0;}}
.shop-overlay{position:absolute;inset:0;z-index:30;display:flex;flex-direction:column;align-items:center;background:linear-gradient(180deg,#0a0e1f 0%,#161033 100%);padding:max(16px,env(safe-area-inset-top)) 16px max(16px,env(safe-area-inset-bottom)) 16px;}
