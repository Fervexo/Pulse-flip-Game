  const hudLevelText=document.getElementById('hudLevelText');
  const hudLevelFill=document.getElementById('hudLevelFill');
  const hudLevelCurrent=document.getElementById('hudLevelCurrent');
  const hudLevelNext=document.getElementById('hudLevelNext');
  const lobbyLevelBadge=document.getElementById('lobbyLevelBadge');
  const lobbyLevelFill=document.getElementById('lobbyLevelFill');
  const lobbyLevelLabel=document.getElementById('lobbyLevelLabel');
  const lobbyCurrentIcon=document.getElementById('lobbyCurrentIcon');
  const lobbyNextIcon=document.getElementById('lobbyNextIcon');
  const startBest=document.getElementById('startBest');
  const soundBtn=document.getElementById('soundBtn');
  const homeBtn=document.getElementById('homeBtn');
  const levelUpBanner=document.getElementById('levelUpBanner');
  const levelUpNum=document.getElementById('levelUpNum');
