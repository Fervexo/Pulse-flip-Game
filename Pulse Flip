.shop-name{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;}
.shop-action{font-family:'Space Grotesk',sans-serif;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;border:none;border-radius:100px;padding:7px 16px;cursor:pointer;width:100%;}
.shop-action.buy{color:var(--bg-bottom);background:linear-gradient(135deg,var(--amber),#ffe98a);}
.shop-action.buy:disabled{color:var(--muted);background:rgba(255,255,255,0.06);cursor:default;}
.shop-action.equip{color:var(--bg-bottom);background:linear-gradient(135deg,var(--cyan),#8ef0ff);}
.shop-action.equipped-label{color:var(--cyan);background:rgba(77,238,234,0.08);border:1px solid rgba(77,238,234,0.3);}
.coin-icon{width:14px;height:14px;border-radius:50%;background:radial-gradient(circle at 32% 32%,#fffbe0,var(--amber) 70%);box-shadow:0 0 8px rgba(255,210,63,0.7);flex-shrink:0;}
.stats-overlay{position:absolute;inset:0;z-index:25;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;background:rgba(10,14,31,0.97);padding:max(20px,env(safe-area-inset-top)) 20px max(16px,env(safe-area-inset-bottom)) 20px;overflow-y:auto;}
.stats-overlay.hidden{display:none;}
.stats-title{font-family:'Archivo Black',sans-serif;font-size:20px;letter-spacing:4px;text-transform:uppercase;background:linear-gradient(135deg,var(--cyan),var(--magenta));-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:18px;margin-top:8px;}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:340px;margin-bottom:18px;}
.stat-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px;text-align:center;}
.stat-value{font-family:'Archivo Black',sans-serif;font-size:26px;color:var(--ink);line-height:1;}
.stat-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:500;margin-top:3px;}
.achievements-grid{width:100%;max-width:340px;display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.achievements-title{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:4px;text-align:left;}
.achievement-row{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:11px;padding:9px 12px;}
.achievement-row.unlocked{border-color:rgba(255,210,63,0.4);}
.ach-icon{font-size:18px;flex-shrink:0;}
.ach-info{flex:1;text-align:left;}
.ach-name{font-size:11px;font-weight:700;letter-spacing:1px;}
.ach-desc{font-size:9px;color:var(--muted);letter-spacing:0.5px;margin-top:1px;}
.ach-locked{font-size:10px;color:var(--muted);margin-left:auto;flex-shrink:0;}
.daily-reward-popup{position:absolute;inset:0;z-index:40;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(10,14,31,0.92);backdrop-filter:blur(8px);padding:24px;}
.daily-reward-popup.hidden{display:none;}
.daily-reward-title{font-family:'Archivo Black',sans-serif;font-size:clamp(20px,6vw,36px);letter-spacing:4px;text-transform:uppercase;background:linear-gradient(135deg,var(--cyan),var(--magenta));-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:6px;}
.daily-reward-sub{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:24px;}
.daily-reward-items{display:flex;flex-direction:column;gap:12px;margin-bottom:28px;width:100%;max-width:280px;}
.daily-reward-item{display:flex;align-items:center;gap:14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:16px;padding:14px 18px;}
.daily-reward-icon{font-size:28px;flex-shrink:0;}
.daily-reward-info{flex:1;text-align:left;}
.daily-reward-name{font-family:'Archivo Black',sans-serif;font-size:15px;letter-spacing:1px;color:var(--amber);}
.daily-reward-desc{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-top:2px;}
.daily-streak-row{display:flex;gap:6px;margin-bottom:20px;justify-content:center;}
.streak-dot{width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:9px;}
.streak-dot.done{background:var(--amber);border-color:var(--amber);color:#0a0e1f;font-weight:700;}
.streak-dot.today{border-color:var(--cyan);color:var(--cyan);font-weight:700;}
</style>
</head>
<body>
<div id="wrap">
  <canvas id="game"></canvas>
  <div class="flash" id="flash"></div>
  <div class="level-flash" id="levelFlash"></div>
  <div class="level-up-popup" id="levelUpPopup"></div>
  <div class="super-flip-banner" id="superFlipBanner">⚡ SUPER FLIP ⚡</div>
  <div class="milestone-popup" id="milestonePopup">
    <div class="milestone-icon" id="milestoneIcon">🏆</div>
    <div class="milestone-title" id="milestoneTitle">MILESTONE</div>
    <div class="milestone-desc" id="milestoneDesc"></div>
  </div>
  <div class="powerup-label" id="powerupLabel"></div>
  <div class="danger-bar top" id="dangerTop"></div>
  <div class="danger-bar bot" id="dangerBot"></div>
  <div class="streak-badge" id="streakBadge">🔥 <span id="streakCount">0</span>x</div>
  <div class="powerup-hud" id="powerupHud"></div>

  <!-- CHARGE BAR -->
  <div class="charge-hud" id="chargeHud">
    <div class="charge-pips" id="chargePips"></div>
    <div class="charge-track"><div class="charge-fill" id="chargeFill"></div></div>
    <div class="charge-label">CHARGE FLIP</div>
  </div>

  <!-- BOSS HUD -->
  <div class="boss-hud" id="bossHud">
    <div class="boss-name" id="bossName">BOSS</div>
    <div class="boss-track"><div class="boss-fill" id="bossFill"></div></div>
  </div>

  <!-- TIMER HUD (Time Attack) -->
  <div class="timer-hud" id="timerHud">30</div>

  <!-- XP BAR -->
  <div class="xp-hud"><div class="xp-fill" id="xpFill" style="width:0%"></div></div>

  <div class="hud">
    <div class="hud-left">
      <div class="score" id="score">0</div>
      <div class="best-hud" id="best">BEST 0</div>
      <div class="hud-coins-row"><span class="coin-icon"></span><span id="hudCoins">0</span></div>
    </div>
    <div class="hud-right">
      <div class="combo" id="combo">CLOSE CALL</div>
    </div>
  </div>

  <div class="level-hud" id="levelHud">
    <div class="level-badge current" id="hudLevelCurrent">1</div>
    <div class="level-hud-mid">
      <div class="level-hud-text" id="hudLevelText">LEVEL 1</div>
      <div class="level-hud-track"><div class="level-hud-fill" id="hudLevelFill"></div></div>
    </div>
    <div class="level-badge next" id="hudLevelNext">2</div>
  </div>

  <button class="sound-btn" id="soundBtn">🔊</button>

  <!-- Daily Reward Popup -->
  <div class="daily-reward-popup hidden" id="dailyRewardPopup">
    <div class="daily-reward-title">DAILY REWARD</div>
    <div class="daily-reward-sub">Come back every day!</div>
    <div class="daily-streak-row" id="dailyStreakRow"></div>
    <div class="daily-reward-items" id="dailyRewardItems"></div>
    <button class="btn" id="claimRewardBtn">Claim!</button>
  </div>

  <!-- Start Screen -->
  <div class="overlay" id="startScreen">
    <div class="lobby-level">
      <div class="lobby-level-row">
        <div class="lobby-level-badge-icon" id="lobbyCurrentIcon">1</div>
        <div class="lobby-level-center">
          <div class="lobby-level-badge" id="lobbyLevelBadge">LEVEL 1</div>
          <div class="lobby-level-track"><div class="lobby-level-fill" id="lobbyLevelFill"></div></div>
          <div class="lobby-level-label" id="lobbyLevelLabel">0 / 10 to next level</div>
        </div>
        <div class="lobby-level-next-icon" id="lobbyNextIcon">2</div>
      </div>
    </div>
    <div id="rankBadgeEl" class="rank-badge" style="color:var(--muted);border-color:var(--muted);display:none;"></div>
    <div class="title">PULSE FLIP</div>
    <div class="subtitle">tap 4x to charge • super flip • don't die</div>
    <div class="lobby-stats">
      <div class="coin-pill"><span class="coin-icon"></span><span id="startCoins">0</span></div>
      <div class="best-pill" id="startBest" style="display:flex;align-items:center;gap:6px;"><span>BEST</span><span id="startBestNum">0</span></div>
    </div>
    <div class="daily-pill" id="dailyChallengeBtn">⚡ DAILY: SCORE 10</div>

    <!-- Mode Select -->
    <div class="mode-select">
      <div class="mode-title">Game Mode</div>
      <div class="mode-grid" id="modeGrid"></div>
    </div>

    <!-- Level navigator -->
    <div class="level-nav-panel" id="levelNavPanel">
      <div class="level-nav-title">Navigate Levels</div>
      <div class="level-nav-scroll" id="levelNavScroll"></div>
    </div>
    <div class="selected-level-btn" id="selectedLevelContainer">
      <div class="selected-level-badge" id="selectedLevelBadge">Starting from Level 1</div>
    </div>

    <button class="btn" id="startBtn" style="margin-bottom:6px;">▶ Play</button>
    <div class="btn-row">
      <button class="btn btn-secondary" id="shopBtnStart">Shop</button>
      <button class="btn btn-secondary" id="statsBtnStart">Stats</button>
      <button class="btn btn-secondary" id="questsBtnStart">Quests</button>
      <button class="btn btn-secondary" id="upgradesBtnStart">Upgrades</button>
    </div>
  </div>

  <!-- Game Over Screen -->
  <div class="overlay hidden gameover" id="overScreen">
    <div class="title">CRUSHED</div>
    <div class="final-score" id="finalScore">0</div>
    <div class="final-label" id="finalLabel">pillars passed</div>
    <div class="coin-pill" id="coinsEarnedPill"><span class="coin-icon"></span><span id="coinsEarned">+0</span></div>
    <div class="coin-multiplier" id="coinsMultiplier"></div>
    <div class="level-up-banner" id="levelUpBanner" style="display:none;">Reached <span id="levelUpNum"></span></div>
    <div class="new-best" id="newBest" style="display:none;">★ new best ★</div>
    <button class="btn" id="retryBtn" style="margin-bottom:6px;">Retry</button>
    <div class="btn-row">
      <button class="btn btn-secondary" id="homeBtn">Home</button>
      <button class="btn btn-secondary" id="shopBtnOver">Shop</button>
      <button class="btn btn-secondary" id="shareBtn">Share</button>
    </div>
  </div>

  <!-- Shop Overlay -->
  <div class="shop-overlay hidden" id="shopOverlay">
    <div class="shop-header">
      <div class="shop-title">SHOP</div>
      <div class="shop-coins-display"><span class="coin-icon"></span><span id="shopCoins">0</span></div>
      <div class="shop-close" id="shopClose">✕</div>
    </div>
    <div class="shop-tabs">
      <div class="shop-tab active" data-tab="skins">Orbs</div>
      <div class="shop-tab" data-tab="trails">Trails</div>
      <div class="shop-tab" data-tab="backgrounds">Worlds</div>
      <div class="shop-tab" data-tab="powerups">Power-ups</div>
    </div>
    <div class="shop-grid" id="shopGrid"></div>
  </div>

  <!-- Stats Overlay -->
  <div class="stats-overlay hidden" id="statsOverlay">
    <div class="stats-title">YOUR STATS</div>
    <div class="stats-grid" id="statsGrid"></div>
    <div class="achievements-grid" id="achievementsGrid">
      <div class="achievements-title">Achievements</div>
    </div>
    <button class="btn" id="statsCloseBtn">Back</button>
  </div>

  <!-- Quests Overlay -->
  <div class="quests-overlay hidden" id="questsOverlay">
    <div class="quests-title">📋 QUESTS</div>
    <div id="questsList" style="width:100%;max-width:340px;"></div>
    <button class="btn" id="questsCloseBtn" style="margin-top:12px;">Back</button>
  </div>

  <!-- Upgrades Overlay -->
  <div class="upgrades-overlay hidden" id="upgradesOverlay">
    <div class="upgrades-title">⚗️ UPGRADES</div>
    <div style="display:inline-flex;align-items:center;gap:7px;background:rgba(255,210,63,0.10);border:1px solid rgba(255,210,63,0.35);border-radius:100px;padding:6px 14px;font-size:14px;font-weight:700;color:var(--amber);margin-bottom:14px;letter-spacing:1px;">
      <span class="coin-icon"></span><span id="upgradesCoins">0</span>
    </div>
    <div id="upgradesList" style="width:100%;max-width:340px;"></div>
    <button class="btn" id="upgradesCloseBtn" style="margin-top:12px;">Back</button>
  </div>
</div>

